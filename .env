#==============================================================================
# SPanel Environment Configuration
# File cấu hình môi trường cho SPanel
#==============================================================================

#------------------------------------------------------------------------------
# Cài đặt
#------------------------------------------------------------------------------
# Thư mục runtime SPanel (nơi cài đặt và chạy thực tế)
SPANEL_DIR="/var/server"
SPANEL_USER="spanel"
SPANEL_GROUP="spanel"

#------------------------------------------------------------------------------
# Nginx
#------------------------------------------------------------------------------

NGINX_VERSION="1.31"
NGINX_USER="www-data"
NGINX_PORT="80"
NGINX_SSL_PORT="443"
NGINX_WORKER_PROCESSES="auto"
NGINX_WORKER_CONNECTIONS="1024"
NGINX_PID_FILE="$SPANEL_DIR/run/nginx.pid"
NGINX_ERROR_LOG="$SPANEL_DIR/logs/nginx/error.log"
NGINX_ACCESS_LOG="$SPANEL_DIR/logs/nginx/access.log"

#------------------------------------------------------------------------------
# Lua
#------------------------------------------------------------------------------

LUAJIT_VERSION="2.1"
LUA_PATH="$SPANEL_DIR/lua/?.lua;;"
LUA_CPATH="$SPANEL_DIR/luajit/lib/lua/5.1/?.so;;"

#------------------------------------------------------------------------------
# Cache
#------------------------------------------------------------------------------

CACHE_ENABLED="true"
CACHE_DIR="$SPANEL_DIR/cache"
CACHE_SIZE="100m"
CACHE_INACTIVE="7d"
CACHE_MAX_SIZE="1g"
CACHE_USE_STALE="error timeout updating"
CACHE_MIN_USES="2"

#------------------------------------------------------------------------------
# WAF
#------------------------------------------------------------------------------

WAF_ENABLED="true"
WAF_LOG_DIR="$SPANEL_DIR/logs/waf"
WAF_RULES_DIR="$SPANEL_DIR/waf/rules"
WAF_MODE="active"
WAF_BLOCK_STATUS_CODE="403"
WAF_LOG_LEVEL="info"

#------------------------------------------------------------------------------
# Database (SQLite)
#------------------------------------------------------------------------------

DB_TYPE="sqlite"
DB_PATH="$SPANEL_DIR/lib/spanel.db"
DB_POOL_SIZE="5"

#------------------------------------------------------------------------------
# SSL
#------------------------------------------------------------------------------

SSL_CERT_DIR="$SPANEL_DIR/ssl"
SSL_PROTOCOL="TLSv1.2 TLSv1.3"
SSL_CIPHERS="ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384"
SSL_PREFERRER_SERVER_CIPHERS="on"

#------------------------------------------------------------------------------
# Rate Limiting
#------------------------------------------------------------------------------

RATE_LIMIT_ENABLED="true"
RATE_LIMIT_REQ_PER_SECOND="10"
RATE_LIMIT_BURST="20"
RATE_LIMIT_CONN_PER_IP="100"

#------------------------------------------------------------------------------
# Log
#------------------------------------------------------------------------------

LOG_LEVEL="info"
LOG_ROTATE_SIZE="100m"
LOG_ROTATE_DAYS="7"

#------------------------------------------------------------------------------
# Backup
#------------------------------------------------------------------------------

BACKUP_ENABLED="true"
BACKUP_DIR="/var/backups"
BACKUP_RETENTION_DAYS="30"
BACKUP_COMPRESSION="gzip"

#------------------------------------------------------------------------------
# System
#------------------------------------------------------------------------------

MAX_UPLOAD_SIZE="100m"
MAX_BODY_SIZE="256m"
PROCESS_TIMEOUT="60"
KEEPALIVE_TIMEOUT="65"
SEND_TIMEOUT="60"