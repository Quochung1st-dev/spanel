[Unit]
Description=SPanel Nginx Service
After=network.target

[Service]
Type=forking
PIDFile=/var/server/run/nginx.pid
ExecStart=/var/server/nginx/sbin/nginx -c /var/server/nginx/conf/nginx.conf
ExecReload=/var/server/nginx/sbin/nginx -s reload
ExecStop=/var/server/nginx/sbin/nginx -s stop
User=root
Group=www-data
WorkingDirectory=/opt/spanel

RuntimeDirectory=spanel
LogsDirectory=spanel
ProtectSystem=full
NoNewPrivileges=true
PrivateTmp=true

Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target