#!/bin/bash
#==============================================================================
# v-add-blocklist
# Them IP vao blocklist
#==============================================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

# Load env
SPANEL_DIR="${SPANEL_DIR:-/var/server}"
BLOCKLIST_FILE="$SPANEL_DIR/waf/blocklist.conf"
NGINX_CONF="$SPANEL_DIR/nginx/conf/nginx.conf"

#------------------------------------------------------------------------------
# Print header
#------------------------------------------------------------------------------

print_header() {
    echo ""
    echo -e "${CYAN}╔════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║         SPanel - Add Blocklist             ║${NC}"
    echo -e "${CYAN}╚════════════════════════════════════════════╝${NC}"
    echo ""
}

#------------------------------------------------------------------------------
# Check root
#------------------------------------------------------------------------------

check_root() {
    if [[ $EUID -ne 0 ]]; then
        log_error "Can chay voi quyen root"
        exit 1
    fi
}

#------------------------------------------------------------------------------
# Usage
#------------------------------------------------------------------------------

usage() {
    echo "Usage: v-add-blocklist <IP> [reason]"
    echo ""
    echo "  IP      - Dia chi IP can chan"
    echo "  reason  - Ly do (tuy chon)"
    echo ""
    echo "Vi du:"
    echo "  v-add-blocklist 1.2.3.4"
    echo "  v-add-blocklist 1.2.3.4 'Brute force attack'"
    echo ""
}

#------------------------------------------------------------------------------
# Add IP to blocklist
#------------------------------------------------------------------------------

add_blocklist() {
    local ip=$1
    local reason="${2:-}"

    # Validate IP format
    if ! [[ "$ip" =~ ^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$ ]]; then
        if ! [[ "$ip" =~ ^[a-fA-F0-9:]+$ ]]; then
            log_error "IP khong hop le: $ip"
            return 1
        fi
    fi

    # Create directory if not exists
    mkdir -p "$(dirname "$BLOCKLIST_FILE")"

    # Check if IP already exists
    if grep -q "^#\?$ip" "$BLOCKLIST_FILE" 2>/dev/null; then
        log_warn "IP $ip da ton tai trong blocklist"
        return 1
    fi

    # Add to blocklist with comment
    if [[ -n "$reason" ]]; then
        echo "# $(date '+%Y-%m-%d %H:%M:%S') - $reason" >> "$BLOCKLIST_FILE"
    fi
    echo "$ip" >> "$BLOCKLIST_FILE"

    log_info "Da them $ip vao blocklist"
    log_info "File: $BLOCKLIST_FILE"

    # Reload nginx bang v-restart
    log_info "Dang reload Nginx..."
    if pgrep nginx > /dev/null 2>&1; then
        v-restart reload-only 2>/dev/null && log_info "Nginx da reload" || log_warn "Loi reload Nginx"
    else
        log_warn "Nginx khong chay, khong can reload"
    fi
}

#------------------------------------------------------------------------------
# Main
#------------------------------------------------------------------------------

main() {
    print_header
    check_root

    if [[ $# -lt 1 ]]; then
        usage
        exit 1
    fi

    add_blocklist "$1" "${2:-}"
}

main "$@"
