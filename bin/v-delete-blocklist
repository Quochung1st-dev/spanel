#!/bin/bash
#==============================================================================
# v-delete-blocklist
# Xoa IP khoi blocklist
#==============================================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

# Load env
SPANEL_DIR="${SPANEL_DIR:-/var/server}"
BLOCKLIST_FILE="$SPANEL_DIR/waf/blocklist.conf"

#------------------------------------------------------------------------------
# Print header
#------------------------------------------------------------------------------

print_header() {
    echo ""
    echo -e "${CYAN}╔════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║         SPanel - Delete Blocklist          ║${NC}"
    echo -e "${CYAN}╚════════════════════════════════════════════╝${NC}"
    echo ""
}

#------------------------------------------------------------------------------
# Check root
#------------------------------------------------------------------------------

check_root() {
    if [[ $EUID -ne 0 ]]; then
        log_error "Can chay voi quyen root"
        exit 1
    fi
}

#------------------------------------------------------------------------------
# Usage
#------------------------------------------------------------------------------

usage() {
    echo "Usage: v-delete-blocklist <IP>"
    echo ""
    echo "  IP - Dia chi IP can xoa khoi blocklist"
    echo ""
    echo "Vi du:"
    echo "  v-delete-blocklist 1.2.3.4"
    echo ""
}

#------------------------------------------------------------------------------
# Delete IP from blocklist
#------------------------------------------------------------------------------

delete_blocklist() {
    local ip=$1

    # Check if file exists
    if [[ ! -f "$BLOCKLIST_FILE" ]]; then
        log_error "File blocklist khong ton tai: $BLOCKLIST_FILE"
        return 1
    fi

    # Check if IP exists
    if ! grep -q "^#\?$ip$" "$BLOCKLIST_FILE" 2>/dev/null; then
        log_warn "IP $ip khong ton tai trong blocklist"
        return 1
    fi

    # Remove IP and its comments
    sed -i "/^#.*$ip/d; /^$ip$/d" "$BLOCKLIST_FILE"

    log_info "Da xoa $ip khoi blocklist"
    log_info "File: $BLOCKLIST_FILE"

    # Reload nginx bang v-restart
    log_info "Dang reload Nginx..."
    if pgrep nginx > /dev/null 2>&1; then
        v-restart reload-only 2>/dev/null && log_info "Nginx da reload" || log_warn "Loi reload Nginx"
    else
        log_warn "Nginx khong chay, khong can reload"
    fi
}

#------------------------------------------------------------------------------
# Main
#------------------------------------------------------------------------------

main() {
    print_header
    check_root

    if [[ $# -lt 1 ]]; then
        usage
        exit 1
    fi

    delete_blocklist "$1"
}

main "$@"
