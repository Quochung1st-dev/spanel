#!/bin/bash
#==============================================================================
# v-check-vps
# Kiem tra thong tin VPS/Server - Dashboard style
#==============================================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
PURPLE='\033[0;35m'
WHITE='\033[1;37m'
NC='\033[0m'
BOLD='\033[1m'
DIM='\033[2m'

# Load .env
if [[ -f /var/server/.env ]]; then
    source /var/server/.env
fi

SPANEL_DIR="${SPANEL_DIR:-/var/server}"
OPENRESTY_DIR="${OPENRESTY_DIR:-/usr/local/openresty}"

W=80  # total width

# Progress bar
bar() {
    local pct=$1 width=15
    local filled=$((pct * width / 100))
    local empty=$((width - filled))
    local b=""
    for ((i=0; i<filled; i++)); do b="${b}#"; done
    for ((i=0; i<empty; i++)); do b="${b}-"; done
    echo "$b"
}

# Color by usage
uc() {
    local pct=$1
    if [[ "$pct" -gt 85 ]]; then echo -e "$RED"
    elif [[ "$pct" -gt 65 ]]; then echo -e "$YELLOW"
    else echo -e "$GREEN"
    fi
}

# Status badge
badge_on()  { echo -e " ${GREEN}ON ${NC} "; }
badge_off() { echo -e " ${RED}OFF${NC} "; }

# Separator
sep() { echo -e "${BLUE}в•џ$(printf 'в”Ђ%.0s' $(seq 1 $((W-2))))в•ў${NC}"; }

# Two-column row: label1 value1  |  label2 value2
row2() {
    local l1="$1" v1="$2" l2="$3" v4="$4"
    printf "${BLUE}в•‘${NC}  %-12s %-24s %-14s %s\n" "$l1" "$v1" "$l2" "$v4"
}

# Single row
row1() {
    local label="$1" value="$2"
    printf "${BLUE}в•‘${NC}  %-14s %s\n" "$label" "$value"
}

#==============================================================================
# Gather data
#==============================================================================

# System
hostname_str=$(hostname)
os_str=$(grep PRETTY_NAME /etc/os-release 2>/dev/null | cut -d'"' -f2 || echo "Unknown")
kernel_str=$(uname -r)
arch_str=$(uname -m)
uptime_str=$(uptime -p 2>/dev/null | sed 's/up //' || echo "Unknown")
load_str=$(awk '{print $1, $2, $3}' /proc/loadavg)
timezone_str=$(timedatectl 2>/dev/null | grep "Time zone" | awk '{print $3}' || cat /etc/timezone 2>/dev/null || echo "N/A")
reboot_str=$(who -b 2>/dev/null | awk '{print $3, $4}' || echo "N/A")
procs=$(ps aux 2>/dev/null | wc -l)
users_str=$(who 2>/dev/null | wc -l)

# CPU
cpu_model=$(grep 'model name' /proc/cpuinfo 2>/dev/null | head -1 | cut -d':' -f2 | sed 's/^ //' | cut -c1-48)
cpu_cores=$(nproc)
cpu_mhz=$(grep 'cpu MHz' /proc/cpuinfo 2>/dev/null | head -1 | awk '{printf "%.0f", $4}' || echo "N/A")
cpu_pct=$(awk '/^cpu /{u=$2+$4; t=u+$5} END{if(t>0) printf "%.0f", u*100/t; else print 0}' /proc/stat)
cpu_cache=$(grep 'cache size' /proc/cpuinfo 2>/dev/null | head -1 | awk '{print $4, $5}' || echo "N/A")

# RAM
ram_total=$(free -m | awk '/^Mem:/{print $2}')
ram_used=$(free -m | awk '/^Mem:/{print $3}')
ram_avail=$(free -m | awk '/^Mem:/{print $7}')
ram_pct=$((ram_used * 100 / ram_total))
ram_buffers=$(free -m | awk '/^Mem:/{print $6}')

# Swap
swap_total=$(free -m | awk '/^Swap:/{print $2}')
swap_used=$(free -m | awk '/^Swap:/{print $3}')
if [[ "$swap_total" -gt 0 ]]; then
    swap_pct=$((swap_used * 100 / swap_total))
else
    swap_pct=0
fi

# Disk
disk_total=$(df -h / | awk 'NR==2{print $2}')
disk_used=$(df -h / | awk 'NR==2{print $3}')
disk_avail=$(df -h / | awk 'NR==2{print $4}')
disk_pct=$(df / | awk 'NR==2{print $5}' | tr -d '%')
inode_pct=$(df -i / | awk 'NR==2{print $5}' | tr -d '%')

# Network
ip_str=$(hostname -I 2>/dev/null | awk '{print $1}' || echo "N/A")
ip_all=$(hostname -I 2>/dev/null || echo "N/A")
gateway_str=$(ip route 2>/dev/null | grep default | awk '{print $3}' || echo "N/A")
dns_str=$(grep nameserver /etc/resolv.conf 2>/dev/null | awk '{print $2}' | tr '\n' ',' | sed 's/,$//' || echo "N/A")
mac_str=$(ip link 2>/dev/null | grep -A1 "$(ip route | grep default | awk '{print $5}' | head -1)" | grep ether | awk '{print $2}' || echo "N/A")
iface_str=$(ip route 2>/dev/null | grep default | awk '{print $5}' | head -1 || echo "N/A")
conns=$(ss -s 2>/dev/null | grep estab | awk '{print $2}' || echo "N/A")

# Services
openresty_on=$(if pgrep -x nginx > /dev/null 2>&1; then echo "on"; else echo "off"; fi)
redis_on=$(if pgrep -x redis-server > /dev/null 2>&1; then echo "on"; else echo "off"; fi)
crowdsec_on=$(if systemctl is-active --quiet crowdsec 2>/dev/null; then echo "on"; else echo "off"; fi)
ssh_on=$(if systemctl is-active --quiet sshd 2>/dev/null || systemctl is-active --quiet ssh 2>/dev/null; then echo "on"; else echo "off"; fi)
firewall_str=$(if command -v ufw > /dev/null 2>&1 && ufw status 2>/dev/null | grep -q "active"; then echo "UFW ON"; elif command -v firewall-cmd > /dev/null 2>&1; then echo "firewalld"; else echo "None"; fi)
openresty_ver=$("$OPENRESTY_DIR/nginx/sbin/nginx" -v 2>&1 | grep -oP '\d+\.\d+\.\d+' || echo "N/A")
nginx_worker=$(pgrep -x nginx 2>/dev/null | wc -l)

# Domains
domain_count=$(ls -d /var/www/*/ 2>/dev/null | wc -l)
domain_list=$(ls -d /var/www/*/ 2>/dev/null | xargs -I{} basename {} | tr '\n' ', ' | sed 's/, $//')

# Paths size
server_size=$(du -sh /var/server 2>/dev/null | awk '{print $1}' || echo "0")
cache_size=$(du -sh /var/cache/nginx 2>/dev/null | awk '{print $1}' || echo "0")
www_size=$(du -sh /var/www 2>/dev/null | awk '{print $1}' || echo "0")
log_size=$(du -sh /var/server/logs 2>/dev/null | awk '{print $1}' || echo "0")
waf_size=$(du -sh /var/server/waf 2>/dev/null | awk '{print $1}' || echo "0")

# Ports
port_80=$(if ss -tlnp 2>/dev/null | grep -q ':80 '; then echo "on"; else echo "off"; fi)
port_443=$(if ss -tlnp 2>/dev/null | grep -q ':443 '; then echo "on"; else echo "off"; fi)
port_22=$(if ss -tlnp 2>/dev/null | grep -q ':22 '; then echo "on"; else echo "off"; fi)

# Top processes
top_cpu=$(ps aux --sort=-%cpu 2>/dev/null | head -4 | tail -3 | awk '{printf "%-14s %s%%\n", substr($11,1,14), $3}')
top_mem=$(ps aux --sort=-%mem 2>/dev/null | head -4 | tail -3 | awk '{printf "%-14s %s%%\n", substr($11,1,14), $4}')

#==============================================================================
# Display
#==============================================================================

clear

echo -e "${BLUE}в•”$(printf 'в•ђ%.0s' $(seq 1 $((W-2))))в•—${NC}"
echo -e "${BLUE}в•‘${NC}                   ${BOLD}${WHITE}SPanel - VPS Dashboard${NC}                         ${BLUE}в•‘${NC}"
echo -e "${BLUE}в• $(printf 'в•ђ%.0s' $(seq 1 $((W-2))))в•Ј${NC}"

#в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ SYSTEM в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
echo -e "${BLUE}в•‘${NC} ${CYAN}SYSTEM${NC}                                                               ${BLUE}в•‘${NC}"
row2 "Hostname:" "${hostname_str}" "Arch:" "${arch_str}"
row2 "OS:" "${os_str}" "Kernel:" "${kernel_str}"
row2 "Uptime:" "${uptime_str}" "Timezone:" "${timezone_str}"
row2 "Last Boot:" "${reboot_str}" "Processes:" "${procs}"
row2 "Logged In:" "${users_str} users" "Load:" "${load_str}"

sep

#в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ CPU в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
cpu_c=$(uc "$cpu_pct")
echo -e "${BLUE}в•‘${NC} ${CYAN}CPU${NC}                                                                  ${BLUE}в•‘${NC}"
echo -e "${BLUE}в•‘${NC}  Model:  ${cpu_model}"
row2 "Cores:" "${cpu_cores}" "Frequency:" "${cpu_mhz} MHz"
echo -e "${BLUE}в•‘${NC}  Usage:  ${cpu_c}$(bar "$cpu_pct")${NC}  ${cpu_c}${cpu_pct}%${NC}                          Cache: ${cpu_cache}"

sep

#в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ MEMORY в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
ram_c=$(uc "$ram_pct")
swap_c=$(uc "$swap_pct")
echo -e "${BLUE}в•‘${NC} ${CYAN}MEMORY${NC}                                                              ${BLUE}в•‘${NC}"
echo -e "${BLUE}в•‘${NC}  RAM   ${ram_c}$(bar "$ram_pct")${NC}  ${ram_c}${ram_pct}%${NC}   Used: ${ram_used}MB / ${ram_total}MB   Free: ${ram_avail}MB"
if [[ "$swap_total" -gt 0 ]]; then
    echo -e "${BLUE}в•‘${NC}  Swap  ${swap_c}$(bar "$swap_pct")${NC}  ${swap_c}${swap_pct}%${NC}   Used: ${swap_used}MB / ${swap_total}MB"
else
    echo -e "${BLUE}в•‘${NC}  Swap  ${DIM}Disabled${NC}"
fi

sep

#в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ DISK в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
disk_c=$(uc "$disk_pct")
echo -e "${BLUE}в•‘${NC} ${CYAN}DISK${NC}                                                                 ${BLUE}в•‘${NC}"
echo -e "${BLUE}в•‘${NC}  /     ${disk_c}$(bar "$disk_pct")${NC}  ${disk_c}${disk_pct}%${NC}   Used: ${disk_used} / ${disk_total}   Avail: ${disk_avail}   Inodes: ${inode_pct}%"
df -h 2>/dev/null | grep '^/dev/' | grep -v ' /$' | while read dev size used avail pct mount; do
    pct_num=$(echo "$pct" | tr -d '%')
    dc=$(uc "$pct_num")
    echo -e "${BLUE}в•‘${NC}  ${mount:0:5}  ${dc}$(bar "$pct_num")${NC}  ${dc}${pct}${NC}   Used: ${used} / ${size}   Avail: ${avail}"
done

sep

#в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ NETWORK в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
echo -e "${BLUE}в•‘${NC} ${CYAN}NETWORK${NC}                                                             ${BLUE}в•‘${NC}"
row2 "Interface:" "${iface_str}" "MAC:" "${mac_str}"
row2 "IPv4:" "${ip_str}" "Gateway:" "${gateway_str}"
row2 "DNS:" "${dns_str}" "Connections:" "${conns}"
echo -e -n "${BLUE}в•‘${NC}  Ports:   "
[[ "$port_80" == "on" ]] && echo -e -n "${GREEN}80${NC}  " || echo -e -n "${RED}80${NC}  "
[[ "$port_443" == "on" ]] && echo -e -n "${GREEN}443${NC}  " || echo -e -n "${RED}443${NC}  "
[[ "$port_22" == "on" ]] && echo -e -n "${GREEN}22${NC}  " || echo -e -n "${RED}22${NC}  "
echo ""

sep

#в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ SERVICES в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
echo -e "${BLUE}в•‘${NC} ${CYAN}SERVICES${NC}                                                            ${BLUE}в•‘${NC}"
echo -e -n "${BLUE}в•‘${NC}  OpenResty ${openresty_ver}"
[[ "$openresty_on" == "on" ]] && echo -e -n "$(badge_on)" || echo -e -n "$(badge_off)"
echo -e "Workers: ${nginx_worker}   Firewall: ${firewall_str}"

echo -e -n "${BLUE}в•‘${NC}  Redis            "
[[ "$redis_on" == "on" ]] && echo -e -n "$(badge_on)" || echo -e -n "$(badge_off)"
echo -e "SSH:      $( [[ "$ssh_on" == "on" ]] && echo -e "${GREEN}ON${NC}" || echo -e "${RED}OFF${NC}" )"

echo -e -n "${BLUE}в•‘${NC}  CrowdSec         "
[[ "$crowdsec_on" == "on" ]] && echo -e -n "$(badge_on)" || echo -e -n "$(badge_off)"
echo ""

sep

#в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ SPANEL в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
echo -e "${BLUE}в•‘${NC} ${CYAN}SPANEL${NC}                                                              ${BLUE}в•‘${NC}"
echo -e "${BLUE}в•‘${NC}  ${CYAN}Path:${NC}                            ${CYAN}Size:${NC}"

# Main paths
echo -e "${BLUE}в•‘${NC}  /var/server                         ${server_size}"
echo -e "${BLUE}в•‘${NC}  /var/cache/nginx                    ${cache_size}"
echo -e "${BLUE}в•‘${NC}  /var/www                             ${www_size}"
echo -e "${BLUE}в•‘${NC}  /var/server/logs                     ${log_size}"
echo -e "${BLUE}в•‘${NC}  /var/server/waf                      ${waf_size}"

echo -e "${BLUE}в•‘${NC}  ${CYAN}Domains (${domain_count}):${NC}"

# Each domain with size
for dir in /var/www/*/; do
    if [[ -d "$dir" ]]; then
        d_name=$(basename "$dir")
        d_size=$(du -sh "$dir" 2>/dev/null | awk '{print $1}' || echo "0")
        echo -e "${BLUE}в•‘${NC}    $d_name  $d_size"
    fi
done

sep

#в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ TOP PROCESSES в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
echo -e "${BLUE}в•‘${NC} ${CYAN}TOP PROCESSES${NC}                                          ${BLUE}в•‘${NC}"
echo -e "${BLUE}в•‘${NC}  ${CYAN}By CPU:${NC}                            ${CYAN}By Memory:${NC}"
while IFS= read -r cpu_line <&3; do
    read -r mem_line <&4
    printf "${BLUE}в•‘${NC}  %-24s  %-24s\n" "$cpu_line" "$mem_line"
done 3< <(echo "$top_cpu") 4< <(echo "$top_mem")

echo -e "${BLUE}в•љ$(printf 'в•ђ%.0s' $(seq 1 $((W-2))))в•ќ${NC}"
echo ""
