#!/bin/bash
#==============================================================================
# v-check-vps
# Kiểm tra thông tin VPS/Server
#==============================================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# Load .env
if [[ -f /var/server/.env ]]; then
    source /var/server/.env
fi

SPANEL_DIR="${SPANEL_DIR:-/var/server}"
OPENRESTY_DIR="${OPENRESTY_DIR:-/usr/local/openresty}"

#------------------------------------------------------------------------------
# Helper functions
#------------------------------------------------------------------------------

print_header() {
    echo ""
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BLUE}  $1${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

#------------------------------------------------------------------------------
# Header
#------------------------------------------------------------------------------

echo ""
echo -e "${BLUE}╔════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║       SPanel - VPS Checker              ║${NC}"
echo -e "${BLUE}╚════════════════════════════════════════╝${NC}"
echo ""

#------------------------------------------------------------------------------
# System Information
#------------------------------------------------------------------------------

print_header "System Information"

echo "  Hostname:    $(hostname)"
echo "  OS:          $(cat /etc/os-release | grep PRETTY_NAME | cut -d'"' -f2)"
echo "  Kernel:      $(uname -r)"
echo "  Uptime:      $(uptime -p 2>/dev/null || uptime | awk '{print $3,$4}')"
echo "  Load Avg:    $(cat /proc/loadavg | awk '{print $1, $2, $3}')"

#------------------------------------------------------------------------------
# CPU & Memory
#------------------------------------------------------------------------------

print_header "CPU & Memory"

echo "  CPU Model:   $(cat /proc/cpuinfo | grep 'model name' | head -1 | cut -d':' -f2 | sed 's/^ //')"
echo "  CPU Cores:   $(nproc)"
echo ""
echo "  Memory:      $(free -h | awk '/^Mem:/ {print $3}') / $(free -h | awk '/^Mem:/ {print $2}') ($(free | awk '/^Mem:/ {printf "%.0f", $3/$2 * 100}'))%"
echo "  Available:   $(free -h | awk '/^Mem:/ {print $7}')"

#------------------------------------------------------------------------------
# Disk Usage
#------------------------------------------------------------------------------

print_header "Disk Usage"

df -h | grep -E '^/dev/' | while IFS= read -r line; do
    disk=$(echo "$line" | awk '{print $1}')
    size=$(echo "$line" | awk '{print $2}')
    used=$(echo "$line" | awk '{print $3}')
    avail=$(echo "$line" | awk '{print $4}')
    use_pct=$(echo "$line" | awk '{print $5}' | tr -d '%')

    if [[ $use_pct -gt 90 ]]; then
        color=$RED
    elif [[ $use_pct -gt 80 ]]; then
        color=$YELLOW
    else
        color=$GREEN
    fi

    echo -e "  ${disk}"
    echo -e "    Size: ${size} | Used: ${used} | Avail: ${avail} | Use: ${color}${use_pct}%${NC}"
done

#------------------------------------------------------------------------------
# Network
#------------------------------------------------------------------------------

print_header "Network"

echo "  IP Address: $(hostname -I | awk '{print $1}')"
echo "  Gateway:    $(ip route 2>/dev/null | grep default | awk '{print $3}' || echo 'N/A')"
echo "  DNS:        $(grep nameserver /etc/resolv.conf 2>/dev/null | head -1 | awk '{print $2}' || echo 'N/A')"
echo ""
echo "  Listening Ports:"

ss -tlnp 2>/dev/null | grep -E '(:80|:443|:22|:8080|:6379)' | while IFS= read -r line; do
    port=$(echo "$line" | grep -oP ':\K[0-9]+' | head -1)
    proto=$(echo "$line" | awk '{print $1}')
    echo -e "    ${CYAN}${port}${NC}/${proto}"
done 2>/dev/null || echo "    Khong the kiem tra ports"

#------------------------------------------------------------------------------
# Services Status
#------------------------------------------------------------------------------

print_header "Services Status"

services_ok=0
services_total=0

# OpenResty/Nginx
if [[ -f "$OPENRESTY_DIR/nginx/sbin/nginx" ]]; then
    nginx_ver=$("$OPENRESTY_DIR/nginx/sbin/nginx" -v 2>&1 | grep -oP '\d+\.\d+\.\d+' || echo "unknown")
    if pgrep -x nginx > /dev/null 2>&1; then
        echo -e "  ${GREEN}✓${NC} OpenResty/Nginx ${nginx_ver}"
        services_ok=$((services_ok + 1))
    else
        echo -e "  ${RED}✗${NC} OpenResty/Nginx ${nginx_ver}"
    fi
else
    echo -e "  ${RED}✗${NC} OpenResty/Nginx (not installed)"
fi
services_total=$((services_total + 1))

# Redis
if command -v redis-server > /dev/null 2>&1; then
    if pgrep -x redis-server > /dev/null 2>&1; then
        echo -e "  ${GREEN}✓${NC} Redis"
        services_ok=$((services_ok + 1))
    else
        echo -e "  ${RED}✗${NC} Redis"
    fi
else
    echo -e "  ${YELLOW}○${NC} Redis (not installed)"
fi
services_total=$((services_total + 1))

# CrowdSec (optional)
/*
if command -v cscli > /dev/null 2>&1; then
    if systemctl is-active --quiet crowdsec 2>/dev/null; then
        echo -e "  ${GREEN}✓${NC} CrowdSec"
        services_ok=$((services_ok + 1))
    else
        echo -e "  ${YELLOW}○${NC} CrowdSec (stopped)"
    fi
else
    echo -e "  ${YELLOW}○${NC} CrowdSec (not installed)"
fi
services_total=$((services_total + 1))
*/

# SPanel Service
if [[ -f /etc/systemd/system/spanel.service ]]; then
    if systemctl is-active --quiet spanel 2>/dev/null; then
        echo -e "  ${GREEN}✓${NC} SPanel Service"
        services_ok=$((services_ok + 1))
    else
        echo -e "  ${RED}✗${NC} SPanel Service"
    fi
else
    echo -e "  ${YELLOW}○${NC} SPanel Service (not installed)"
fi
services_total=$((services_total + 1))

#------------------------------------------------------------------------------
# SPanel Info
#------------------------------------------------------------------------------

print_header "SPanel"

if [[ -d "$SPANEL_DIR" ]]; then
    echo -e "  ${GREEN}✓${NC} SPanel installed at ${SPANEL_DIR}"

    if [[ -f "$SPANEL_DIR/.env" ]]; then
        echo -e "  ${GREEN}✓${NC} Config: $SPANEL_DIR/.env"
    else
        echo -e "  ${RED}✗${NC} Config: $SPANEL_DIR/.env (missing)"
    fi

    echo "  OpenResty:   ${OPENRESTY_VERSION:-N/A}"
    echo "  Nginx:       ${NGINX_VERSION:-N/A}"
    echo ""
    echo "  Directories:"

    if [[ -d "$SPANEL_DIR/nginx" ]]; then
        echo -e "    ${GREEN}✓${NC} nginx"
    else
        echo -e "    ${RED}✗${NC} nginx"
    fi

    if [[ -d "$SPANEL_DIR/lua" ]]; then
        echo -e "    ${GREEN}✓${NC} lua"
    else
        echo -e "    ${RED}✗${NC} lua"
    fi

    if [[ -d "$SPANEL_DIR/waf" ]]; then
        echo -e "    ${GREEN}✓${NC} waf"
    else
        echo -e "    ${RED}✗${NC} waf"
    fi

    if [[ -d "$SPANEL_DIR/ssl" ]]; then
        echo -e "    ${GREEN}✓${NC} ssl"
    else
        echo -e "    ${RED}✗${NC} ssl"
    fi

    if [[ -d "$SPANEL_DIR/logs" ]]; then
        echo -e "    ${GREEN}✓${NC} logs"
    else
        echo -e "    ${RED}✗${NC} logs"
    fi

    echo ""
    if [[ -d "$SPANEL_DIR/nginx/sites-enabled" ]]; then
        domain_count=$(ls "$SPANEL_DIR/nginx/sites-enabled"/*.conf 2>/dev/null | wc -l || echo 0)
        echo "  Domains:     ${domain_count}"
    else
        echo "  Domains:     0"
    fi
else
    echo -e "  ${RED}✗${NC} SPanel not installed"
fi

#------------------------------------------------------------------------------
# Summary
#------------------------------------------------------------------------------

print_header "Summary"

echo "  Services:    ${services_ok}/${services_total} running"
echo "  Checked at:  $(date '+%Y-%m-%d %H:%M:%S')"
echo ""

if [[ $services_ok -eq $services_total ]]; then
    echo -e "  ${GREEN}All services are running properly!${NC}"
else
    echo -e "  ${YELLOW}Some services are not running.${NC}"
fi

echo ""