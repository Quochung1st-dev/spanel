#!/bin/bash
#==============================================================================
# v-check-vps
# Kiểm tra thông tin VPS/Server
#==============================================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# Load .env
if [[ -f /var/server/.env ]]; then
    source /var/server/.env
fi

SPANEL_DIR="${SPANEL_DIR:-/var/server}"
OPENRESTY_DIR="${OPENRESTY_DIR:-/usr/local/openresty}"

#------------------------------------------------------------------------------
# Helper functions
#------------------------------------------------------------------------------

print_header() {
    echo ""
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BLUE}  $1${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

print_ok() {
    echo -e "${GREEN}✓${NC} $1"
}

print_warn() {
    echo -e "${YELLOW}✗${NC} $1"
}

print_info() {
    echo -e "${CYAN}•${NC} $1"
}

check_service_status() {
    local service=$1
    local display_name=$2

    if systemctl is-active --quiet $service 2>/dev/null; then
        echo -e "  ${display_name}: ${GREEN}running${NC}"
        return 0
    elif pgrep -x $service > /dev/null 2>&1 || pgrep -f "$service" > /dev/null 2>&1; then
        echo -e "  ${display_name}: ${YELLOW}running (manual)${NC}"
        return 0
    else
        echo -e "  ${display_name}: ${RED}stopped${NC}"
        return 1
    fi
}

#------------------------------------------------------------------------------
# Header
#------------------------------------------------------------------------------

echo ""
echo -e "${BLUE}╔════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║       SPanel - VPS Checker              ║${NC}"
echo -e "${BLUE}╚════════════════════════════════════════╝${NC}"
echo ""

#------------------------------------------------------------------------------
# System Information
#------------------------------------------------------------------------------

print_header "System Information"

echo "  Hostname:    $(hostname)"
echo "  OS:          $(cat /etc/os-release | grep PRETTY_NAME | cut -d'"' -f2)"
echo "  Kernel:      $(uname -r)"
echo "  Uptime:      $(uptime -p 2>/dev/null || uptime | awk '{print $3,$4}')"
echo "  Load Avg:    $(cat /proc/loadavg | awk '{print $1, $2, $3}')"

#------------------------------------------------------------------------------
# CPU & Memory
#------------------------------------------------------------------------------

print_header "CPU & Memory"

local cpu_model=$(cat /proc/cpuinfo | grep "model name" | head -1 | cut -d':' -f2 | sed 's/^ //')
local cpu_cores=$(nproc)

echo "  CPU Model:   ${cpu_model}"
echo "  CPU Cores:   ${cpu_cores}"
echo ""

local mem_total=$(free -h | awk '/^Mem:/ {print $2}')
local mem_used=$(free -h | awk '/^Mem:/ {print $3}')
local mem_free=$(free -h | awk '/^Mem:/ {print $4}')
local mem_pct=$(free | awk '/^Mem:/ {printf "%.0f", $3/$2 * 100}')

echo "  Memory:      ${mem_used} / ${mem_total} (${mem_pct}%)"
echo "  Available:   ${mem_free}"

#------------------------------------------------------------------------------
# Disk Usage
#------------------------------------------------------------------------------

print_header "Disk Usage"

df -h | grep -E '^/dev/' | while read line; do
    local disk=$(echo $line | awk '{print $1}')
    local size=$(echo $line | awk '{print $2}')
    local used=$(echo $line | awk '{print $3}')
    local avail=$(echo $line | awk '{print $4}')
    local use_pct=$(echo $line | awk '{print $5}' | tr -d '%')

    local color=$GREEN
    if [[ $use_pct -gt 80 ]]; then
        color=$YELLOW
    fi
    if [[ $use_pct -gt 90 ]]; then
        color=$RED
    fi

    echo -e "  ${disk}"
    echo -e "    Size: ${size} | Used: ${used} | Avail: ${avail} | Use: ${color}${use_pct}%${NC}"
done

#------------------------------------------------------------------------------
# Network
#------------------------------------------------------------------------------

print_header "Network"

local ip_addr=$(hostname -I | awk '{print $1}')
local gateway=$(ip route 2>/dev/null | grep default | awk '{print $3}' || echo "N/A")
local dns=$(grep nameserver /etc/resolv.conf 2>/dev/null | head -1 | awk '{print $2}' || echo "N/A")

echo "  IP Address: ${ip_addr}"
echo "  Gateway:    ${gateway}"
echo "  DNS:        ${dns}"

# Check network ports
echo ""
echo "  Listening Ports:"
ss -tlnp 2>/dev/null | grep -E '(:80|:443|:22|:8080|:6379)' | while read line; do
    local port=$(echo $line | grep -oP ':\K[0-9]+' | head -1)
    local proto=$(echo $line | awk '{print $1}')
    local state=$(echo $line | awk '{print $2}')
    echo -e "    ${CYAN}${port}${NC}/${proto} - ${state}"
done 2>/dev/null || echo "    Không thể kiểm tra ports"

#------------------------------------------------------------------------------
# Services Status
#------------------------------------------------------------------------------

print_header "Services Status"

local services_ok=0
local services_total=0

check_service() {
    local service=$1
    local display_name=$2
    services_total=$((services_total + 1))

    if systemctl is-active --quiet $service 2>/dev/null; then
        echo -e "  ${GREEN}✓${NC} ${display_name}"
        services_ok=$((services_ok + 1))
    elif pgrep -x $service > /dev/null 2>&1 || pgrep -f "$service" > /dev/null 2>&1; then
        echo -e "  ${YELLOW}○${NC} ${display_name} (manual)"
        services_ok=$((services_ok + 1))
    else
        echo -e "  ${RED}✗${NC} ${display_name}"
    fi
}

# OpenResty/Nginx
if [[ -f "$OPENRESTY_DIR/nginx/sbin/nginx" ]]; then
    local nginx_ver=$("$OPENRESTY_DIR/nginx/sbin/nginx" -v 2>&1 | grep -oP '\d+\.\d+\.\d+')
    if pgrep -x nginx > /dev/null 2>&1; then
        echo -e "  ${GREEN}✓${NC} OpenResty/Nginx ${nginx_ver}"
        services_ok=$((services_ok + 1))
    else
        echo -e "  ${RED}✗${NC} OpenResty/Nginx ${nginx_ver}"
    fi
else
    echo -e "  ${RED}✗${NC} OpenResty/Nginx (not installed)"
fi
services_total=$((services_total + 1))

# Redis
if command -v redis-server > /dev/null 2>&1; then
    if pgrep -x redis-server > /dev/null 2>&1; then
        echo -e "  ${GREEN}✓${NC} Redis"
        services_ok=$((services_ok + 1))
    else
        echo -e "  ${RED}✗${NC} Redis"
    fi
else
    echo -e "  ${YELLOW}○${NC} Redis (not installed)"
fi
services_total=$((services_total + 1))

# CrowdSec
if command -v cscli > /dev/null 2>&1; then
    if systemctl is-active --quiet crowdsec 2>/dev/null; then
        echo -e "  ${GREEN}✓${NC} CrowdSec"
        services_ok=$((services_ok + 1))
    else
        echo -e "  ${RED}✗${NC} CrowdSec"
    fi
else
    echo -e "  ${YELLOW}○${NC} CrowdSec (not installed)"
fi
services_total=$((services_total + 1))

# SPanel Service
if [[ -f /etc/systemd/system/spanel.service ]]; then
    check_service "spanel" "SPanel Service"
else
    echo -e "  ${YELLOW}○${NC} SPanel Service (not installed)"
fi
services_total=$((services_total + 1))

#------------------------------------------------------------------------------
# SPanel Info
#------------------------------------------------------------------------------

print_header "SPanel"

if [[ -d "$SPANEL_DIR" ]]; then
    echo -e "  ${GREEN}✓${NC} SPanel installed at ${SPANEL_DIR}"

    # Config
    if [[ -f "$SPANEL_DIR/.env" ]]; then
        echo -e "  ${GREEN}✓${NC} Config: $SPANEL_DIR/.env"
    else
        echo -e "  ${RED}✗${NC} Config: $SPANEL_DIR/.env (missing)"
    fi

    # Version info
    echo "  OpenResty:   ${OPENRESTY_VERSION:-N/A}"
    echo "  Nginx:      ${NGINX_VERSION:-N/A}"

    # Directories
    echo ""
    echo "  Directories:"
    [[ -d "$SPANEL_DIR/nginx" ]] && echo -e "    ${GREEN}✓${NC} nginx" || echo -e "    ${RED}✗${NC} nginx"
    [[ -d "$SPANEL_DIR/lua" ]] && echo -e "    ${GREEN}✓${NC} lua" || echo -e "    ${RED}✗${NC} lua"
    [[ -d "$SPANEL_DIR/waf" ]] && echo -e "    ${GREEN}✓${NC} waf" || echo -e "    ${RED}✗${NC} waf"
    [[ -d "$SPANEL_DIR/ssl" ]] && echo -e "    ${GREEN}✓${NC} ssl" || echo -e "    ${RED}✗${NC} ssl"
    [[ -d "$SPANEL_DIR/logs" ]] && echo -e "    ${GREEN}✓${NC} logs" || echo -e "    ${RED}✗${NC} logs"

    # Domains count
    echo ""
    if [[ -d "$SPANEL_DIR/nginx/sites-enabled" ]]; then
        local domain_count=$(ls $SPANEL_DIR/nginx/sites-enabled/*.conf 2>/dev/null | wc -l)
        echo "  Domains:     ${domain_count}"
    else
        echo "  Domains:     0"
    fi
else
    echo -e "  ${RED}✗${NC} SPanel not installed"
fi

#------------------------------------------------------------------------------
# Summary
#------------------------------------------------------------------------------

print_header "Summary"

echo "  Services:    ${services_ok}/${services_total} running"
echo "  Checked at:  $(date '+%Y-%m-%d %H:%M:%S')"
echo ""

if [[ $services_ok -eq $services_total ]]; then
    echo -e "  ${GREEN}All services are running properly!${NC}"
else
    echo -e "  ${YELLOW}Some services are not running.${NC}"
fi

echo ""
