#!/bin/bash
#==============================================================================
# v-manager-domain
# Menu quản lý domain trong SPanel
#==============================================================================

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

SPANEL_DIR="${SPANEL_DIR:-/var/server}"
NGINX_CONF_DIR="$SPANEL_DIR/nginx"

#------------------------------------------------------------------------------
# Menu chính
#------------------------------------------------------------------------------

show_menu() {
    clear
    echo -e "${BLUE}========================================${NC}"
    echo -e "${BLUE}  SPanel - Domain Manager${NC}"
    echo -e "${BLUE}========================================${NC}"
    echo ""
    echo -e "${GREEN}1)${NC} Danh sách domain"
    echo -e "${GREEN}2)${NC} Tạo domain mới"
    echo -e "${GREEN}3)${NC} Xem chi tiết domain"
    echo -e "${GREEN}4)${NC} Enable/Disable domain"
    echo -e "${GREEN}5)${NC} Xóa domain"
    echo -e "${GREEN}6)${NC} Thêm SSL cho domain"
    echo -e "${GREEN}7)${NC} Kiểm tra SSL"
    echo -e "${GREEN}0)${NC} Thoát"
    echo ""
    echo -e "${YELLOW}Lưu ý: Cần chạy với quyền root${NC}"
    echo ""
}

#------------------------------------------------------------------------------
# Danh sách domain
#------------------------------------------------------------------------------

list_domains() {
    echo -e "${BLUE}[ Danh sách Domain ]${NC}"
    echo ""

    echo -e "${GREEN}Enabled domains:${NC}"
    if [[ -d $NGINX_CONF_DIR/sites-enabled ]]; then
        for conf in $NGINX_CONF_DIR/sites-enabled/*; do
            if [[ -L $conf ]]; then
                local domain=$(basename $conf .conf)
                local status="${GREEN}active${NC}"

                # Check if nginx config is valid
                if ! $SPANEL_DIR/nginx/sbin/nginx -t 2>/dev/null; then
                    status="${RED}config error${NC}"
                fi

                echo -e "  - $domain ($status)"
            fi
        done
    else
        echo "  (không có domain nào)"
    fi

    echo ""
    echo -e "${YELLOW}Available domains:${NC}"
    if [[ -d $NGINX_CONF_DIR/sites-available ]]; then
        for conf in $NGINX_CONF_DIR/sites-available/*.conf; do
            if [[ -f $conf ]]; then
                local domain=$(basename $conf .conf)
                if [[ -L $NGINX_CONF_DIR/sites-enabled/$domain.conf ]]; then
                    continue
                fi
                echo -e "  - $domain ${YELLOW}(disabled)${NC}"
            fi
        done
    fi

    echo ""
}

#------------------------------------------------------------------------------
# Tạo domain mới
#------------------------------------------------------------------------------

create_domain() {
    echo -e "${BLUE}[ Tạo Domain Mới ]${NC}"
    echo ""

    read -p "Nhập domain: " domain
    if [[ -z $domain ]]; then
        echo -e "${RED}Domain không được để trống${NC}"
        return 1
    fi

    read -p "Port (mặc định 80): " port
    port=${port:-80}

    read -p "Enable SSL? (y/n): " enable_ssl
    enable_ssl=${enable_ssl:-n}

    echo ""
    echo -e "${YELLOW}Đang tạo domain $domain...${NC}"

    if [[ -f $SPANEL_DIR/bin/v-add-domain ]]; then
        bash $SPANEL_DIR/bin/v-add-domain $domain $port $enable_ssl
    else
        echo -e "${RED}Không tìm thấy v-add-domain script${NC}"
        return 1
    fi
}

#------------------------------------------------------------------------------
# Xem chi tiết domain
#------------------------------------------------------------------------------

show_domain_detail() {
    echo -e "${BLUE}[ Chi tiết Domain ]${NC}"
    echo ""

    read -p "Nhập domain: " domain
    if [[ -z $domain ]]; then
        echo -e "${RED}Domain không được để trống${NC}"
        return 1
    fi

    local domain_dir="$SCRIPT_DIR/var/www/$domain"

    if [[ ! -d $domain_dir ]]; then
        echo -e "${RED}Domain không tồn tại${NC}"
        return 1
    fi

    echo -e "${GREEN}Thông tin domain: $domain${NC}"
    echo "----------------------------------------"
    echo "Webroot: $domain_dir/public_html"
    echo "Logs: $domain_dir/logs"
    echo "Config: $NGINX_CONF_DIR/sites-available/$domain.conf"

    if [[ -f $SPANEL_DIR/ssl/$domain/fullchain.pem ]]; then
        echo -e "SSL: ${GREEN}Đã cài đặt${NC}"
        echo "Certificate: $SPANEL_DIR/ssl/$domain/fullchain.pem"
    else
        echo -e "SSL: ${YELLOW}Chưa cài đặt${NC}"
    fi

    echo ""
    echo "----------------------------------------"
    echo -e "${CYAN}Disk usage:${NC}"
    du -sh $domain_dir 2>/dev/null || echo "N/A"

    echo ""
    echo -e "${CYAN}Last lines of error log:${NC}"
    tail -5 $domain_dir/logs/nginx/error.log 2>/dev/null || echo "(no log)"
}

#------------------------------------------------------------------------------
# Enable/Disable domain
#------------------------------------------------------------------------------

toggle_domain() {
    echo -e "${BLUE}[ Enable/Disable Domain ]${NC}"
    echo ""

    echo "1) Enable domain"
    echo "2) Disable domain"
    echo "0) Quay lại"
    echo ""

    read -p "Chọn: " choice

    case $choice in
        1)
            read -p "Nhập domain: " domain
            if [[ -f $SPANEL_DIR/bin/v-add-domain ]]; then
                bash $SPANEL_DIR/bin/v-add-domain $domain 80 n enable
            fi
            ;;
        2)
            read -p "Nhập domain: " domain
            if [[ -f $SPANEL_DIR/bin/v-delete-domain ]]; then
                bash $SPANEL_DIR/bin/v-delete-domain $domain disable
            fi
            ;;
    esac
}

#------------------------------------------------------------------------------
# Xóa domain
#------------------------------------------------------------------------------

delete_domain() {
    echo -e "${BLUE}[ Xóa Domain ]${NC}"
    echo ""
    echo -e "${RED}Cảnh báo: Hành động này sẽ xóa domain và tất cả dữ liệu!${NC}"
    echo ""

    read -p "Nhập domain cần xóa: " domain
    if [[ -z $domain ]]; then
        echo -e "${RED}Domain không được để trống${NC}"
        return 1
    fi

    read -p "Xác nhận xóa $domain? (type 'yes' to confirm): " confirm
    if [[ $confirm != "yes" ]]; then
        echo "Đã hủy"
        return 1
    fi

    if [[ -f $SPANEL_DIR/bin/v-delete-domain ]]; then
        bash $SPANEL_DIR/bin/v-delete-domain $domain delete
    fi
}

#------------------------------------------------------------------------------
# Thêm SSL
#------------------------------------------------------------------------------

add_ssl() {
    echo -e "${BLUE}[ Thêm SSL cho Domain ]${NC}"
    echo ""

    echo "1) Let's Encrypt (miễn phí)"
    echo "2) Self-signed (cho testing)"
    echo "0) Quay lại"
    echo ""

    read -p "Chọn: " choice

    case $choice in
        1)
            read -p "Nhập domain: " domain
            read -p "Email (cho Let's Encrypt): " email
            bash $SPANEL_DIR/bin/v-add-domain $domain 443 y letsencrypt $email
            ;;
        2)
            read -p "Nhập domain: " domain
            bash $SPANEL_DIR/bin/v-add-domain $domain 443 y selfsigned
            ;;
    esac
}

#------------------------------------------------------------------------------
# Kiểm tra SSL
#------------------------------------------------------------------------------

check_ssl() {
    echo -e "${BLUE}[ Kiểm tra SSL ]${NC}"
    echo ""

    read -p "Nhập domain: " domain
    if [[ -z $domain ]]; then
        echo -e "${RED}Domain không được để trống${NC}"
        return 1
    fi

    local cert_file="$SPANEL_DIR/ssl/$domain/fullchain.pem"

    if [[ ! -f $cert_file ]]; then
        echo -e "${RED}Certificate không tồn tại cho $domain${NC}"
        return 1
    fi

    echo -e "${GREEN}Certificate info cho $domain:${NC}"
    echo "----------------------------------------"
    openssl x509 -in $cert_file -noout -dates
    echo ""
    openssl x509 -in $cert_file -noout -subject
    echo ""
    openssl x509 -in $cert_file -noout -issuer
}

#------------------------------------------------------------------------------
# MAIN
#------------------------------------------------------------------------------

main() {
    if [[ $EUID -ne 0 ]]; then
        echo -e "${RED}Script phải được chạy với quyền root${NC}"
        exit 1
    fi

    while true; do
        show_menu
        read -p "Chọn: " choice

        case $choice in
            1) list_domains ;;
            2) create_domain ;;
            3) show_domain_detail ;;
            4) toggle_domain ;;
            5) delete_domain ;;
            6) add_ssl ;;
            7) check_ssl ;;
            0) echo "Thoát..."; exit 0 ;;
            *) echo -e "${RED}Lựa chọn không hợp lệ${NC}" ;;
        esac

        echo ""
        read -p "Nhấn Enter để tiếp tục..."
    done
}

main "$@"