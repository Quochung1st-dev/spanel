#!/bin/bash
#==============================================================================
# v-sync-all
# Sync domain/SSL tu remote server ve local
#==============================================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

SPANEL_DIR="${SPANEL_DIR:-/var/server}"
CONFIG_DIR="$SPANEL_DIR/sync"
WWW_DIR="/var/www"

#------------------------------------------------------------------------------
# Check root
#------------------------------------------------------------------------------

check_root() {
    if [[ $EUID -ne 0 ]]; then
        log_error "Can chay voi quyen root"
        exit 1
    fi
}

#------------------------------------------------------------------------------
# Print header
#------------------------------------------------------------------------------

print_header() {
    echo ""
    echo -e "${BLUE}╔════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║       SPanel - Sync All                 ║${NC}"
    echo -e "${BLUE}╚════════════════════════════════════════╝${NC}"
}

#------------------------------------------------------------------------------
# Usage
#------------------------------------------------------------------------------

usage() {
    echo ""
    echo "Usage: v-sync-all <action> [options]"
    echo ""
    echo "Actions:"
    echo "  list          Hien thi danh sach domain tren remote"
    echo "  domains       Sync danh sach domain ve local"
    echo "  ssl           Sync SSL certificates ve local"
    echo "  all           Sync tat ca (domains + SSL)"
    echo ""
    echo "Options:"
    echo "  --name        Ten server"
    echo "  --id          Chon server theo so thu tu"
    echo ""
    echo "Examples:"
    echo "  v-sync-all list"
    echo "  v-sync-all list --id 1"
    echo "  v-sync-all all --id 1"
    exit 1
}

#------------------------------------------------------------------------------
# Create config directory
#------------------------------------------------------------------------------

init_config() {
    mkdir -p "$CONFIG_DIR"
    chmod 700 "$CONFIG_DIR"
}

#------------------------------------------------------------------------------
# Get all servers as array
#------------------------------------------------------------------------------

get_servers_array() {
    local servers=()

    for conf in "$CONFIG_DIR"/*.conf; do
        [[ -f "$conf" ]] || continue
        source "$conf"
        # Include all fields for storage, but only use first 5 for list display
        local entry="$SYNC_NAME|$SYNC_HOST|$SYNC_PORT|$SYNC_USER|$SYNC_METHOD|$SYNC_PASSWORD|$SYNC_KEY_FILE"
        servers+=("$entry")
    done

    echo "${servers[@]}"
}

#------------------------------------------------------------------------------
# List servers with numbers
#------------------------------------------------------------------------------

list_servers() {
    echo ""
    echo -e "${CYAN}Danh sach server:${NC}"
    echo ""

    local servers=$(get_servers_array)

    if [[ -z "$servers" ]]; then
        log_warn "Chua co server nao"
        echo ""
        echo "Su dung: v-sync-config add"
        echo ""
        return
    fi

    local i=1
    echo "  #  | Name             | Host                  | Port | User              | Method"
    echo "-----|------------------|----------------------|------|-------------------|--------"

    for server in $servers; do
        IFS='|' read -r name host port user method _ <<< "$server"
        printf "%4d | %-16s | %-20s | %-4s | %-17s | %s\n" "$i" "$name" "$host" "$port" "$user" "$method"
        ((i++))
    done

    echo ""
}

#------------------------------------------------------------------------------
# Get server config by number
#------------------------------------------------------------------------------

get_server_by_number() {
    local num=$1
    local servers=$(get_servers_array)
    local i=1

    for server in $servers; do
        if [[ $i -eq $num ]]; then
            IFS='|' read -r SYNC_NAME SYNC_HOST SYNC_PORT SYNC_USER SYNC_METHOD <<< "$server"
            # Load full config
            source "$CONFIG_DIR/$SYNC_NAME.conf"
            return 0
        fi
        ((i++))
    done

    return 1
}

#------------------------------------------------------------------------------
# Get server count
#------------------------------------------------------------------------------

get_server_count() {
    local count=0
    for conf in "$CONFIG_DIR"/*.conf; do
        [[ -f "$conf" ]] && ((count++))
    done
    echo $count
}

#------------------------------------------------------------------------------
# Get server config by name
#------------------------------------------------------------------------------

get_server_config() {
    local name=$1

    local conf_file="$CONFIG_DIR/$name.conf"
    if [[ -f "$conf_file" ]]; then
        source "$conf_file"
        return 0
    fi
    return 1
}

#------------------------------------------------------------------------------
# Build SSH command
#------------------------------------------------------------------------------

build_ssh_cmd() {
    local ssh_opts="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o ConnectTimeout=10"

    if [[ "$SYNC_METHOD" == "key" ]]; then
        ssh_opts="$ssh_opts -i $SYNC_KEY_FILE"
        echo "ssh $ssh_opts -p $SYNC_PORT $SYNC_USER@$SYNC_HOST"
    elif [[ -n "$SYNC_PASSWORD" ]]; then
        local pass=$(echo "$SYNC_PASSWORD" | base64 -d 2>/dev/null || echo "")
        echo "sshpass -p '$pass' ssh $ssh_opts -p $SYNC_PORT $SYNC_USER@$SYNC_HOST"
    else
        echo "ssh $ssh_opts -p $SYNC_PORT $SYNC_USER@$SYNC_HOST"
    fi
}

#------------------------------------------------------------------------------
# List domains on remote
#------------------------------------------------------------------------------

list_remote_domains() {
    local ssh_cmd=$(build_ssh_cmd)

    echo ""
    echo -e "${CYAN}Danh sach domain tren remote server:${NC}"
    echo ""

    # Get list of domains from /var/www
    $ssh_cmd "ls -1 /var/www 2>/dev/null" 2>/dev/null | while read domain; do
        local ssl_status="NO"
        local ssl_dir="/var/www/$domain/ssl"

        # Check SSL
        if $ssh_cmd "test -f $ssl_dir/fullchain.pem" 2>/dev/null; then
            ssl_status="SSL"
        fi

        printf "%-30s %s\n" "$domain" "$ssl_status"
    done

    echo ""
}

#------------------------------------------------------------------------------
# Get domain info from remote
#------------------------------------------------------------------------------

get_remote_domain_info() {
    local ssh_cmd=$(build_ssh_cmd)
    local domain=$1

    if ! $ssh_cmd "test -d /var/www/$domain" 2>/dev/null; then
        return 1
    fi

    echo "Domain: $domain"
    echo "Public HTML: $($ssh_cmd "du -sh /var/www/$domain/public_html 2>/dev/null" | awk '{print $1}')"
    echo "SSL: $($ssh_cmd "test -f /var/www/$domain/ssl/fullchain.pem && echo 'YES' || echo 'NO'" 2>/dev/null)"

    if $ssh_cmd "test -f /var/www/$domain/ssl/fullchain.pem" 2>/dev/null; then
        echo "SSL Expiry: $($ssh_cmd "openssl x509 -enddate -noout -in /var/www/$domain/ssl/fullchain.pem 2>/dev/null | cut -d= -f2" 2>/dev/null)"
    fi
}

#------------------------------------------------------------------------------
# Sync domains to local
#------------------------------------------------------------------------------

sync_domains() {
    local ssh_cmd=$(build_ssh_cmd)

    echo ""
    log_info "Bat dau sync domains..."

    local domains=$($ssh_cmd "ls -1 /var/www 2>/dev/null" 2>/dev/null)

    if [[ -z "$domains" ]]; then
        log_warn "Khong co domain nao tren remote"
        return 0
    fi

    echo ""
    echo -e "${CYAN}Cac domain tren remote:${NC}"
    echo "$domains" | while read domain; do
        echo "  - $domain"
    done
    echo ""

    for domain in $domains; do
        echo ""
        echo -e "${CYAN}Xu ly domain: $domain${NC}"

        if [[ -d "$WWW_DIR/$domain" ]]; then
            log_warn "Domain '$domain' da ton tai local, bo qua"
            continue
        fi

        log_info "Tao domain '$domain'..."

        mkdir -p "$WWW_DIR/$domain/public_html"
        mkdir -p "$WWW_DIR/$domain/logs"
        mkdir -p "$WWW_DIR/$domain/config"
        mkdir -p "$WWW_DIR/$domain/ssl"

        log_info "Sync public_html..."
        $ssh_cmd "tar -C /var/www/$domain -c public_html" | tar -x -C "$WWW_DIR/$domain" 2>/dev/null || true

        if $ssh_cmd "test -f /var/www/$domain/ssl/fullchain.pem" 2>/dev/null; then
            log_info "Domain co SSL, sync certificate..."
            $ssh_cmd "cat /var/www/$domain/ssl/fullchain.pem" > "$WWW_DIR/$domain/ssl/fullchain.pem" 2>/dev/null || true
            $ssh_cmd "cat /var/www/$domain/ssl/privkey.pem" > "$WWW_DIR/$domain/ssl/privkey.pem" 2>/dev/null || true
            create_ssl_vhost "$domain"
        else
            create_http_vhost "$domain"
        fi

        log_info "Da sync domain '$domain'"
    done

    /usr/local/openresty/nginx/sbin/nginx -t 2>/dev/null && pkill nginx 2>/dev/null || true
    sleep 1
    /usr/local/openresty/nginx/sbin/nginx -c /var/server/nginx/conf/nginx.conf

    echo ""
    log_info "Da sync tat ca domains!"
    echo ""
}

#------------------------------------------------------------------------------
# Sync SSL certificates
#------------------------------------------------------------------------------

sync_ssl() {
    local ssh_cmd=$(build_ssh_cmd)

    echo ""
    log_info "Bat dau sync SSL..."

    local domains=$($ssh_cmd "find /var/www -name fullchain.pem -path '*/ssl/*' 2>/dev/null | sed 's|/ssl/fullchain.pem||' | xargs -I{} basename {}" 2>/dev/null)

    if [[ -z "$domains" ]]; then
        log_warn "Khong co SSL nao tren remote"
        return 0
    fi

    for domain in $domains; do
        echo ""
        echo -e "${CYAN}Sync SSL: $domain${NC}"

        mkdir -p "$WWW_DIR/$domain/ssl"

        $ssh_cmd "cat /var/www/$domain/ssl/fullchain.pem" > "$WWW_DIR/$domain/ssl/fullchain.pem" 2>/dev/null
        $ssh_cmd "cat /var/www/$domain/ssl/privkey.pem" > "$WWW_DIR/$domain/ssl/privkey.pem" 2>/dev/null

        if [[ -f "/var/server/nginx/conf/sites-available/$domain.conf" ]]; then
            update_vhost_ssl "$domain"
        fi

        log_info "Da sync SSL cho '$domain'"
    done

    echo ""
    log_info "Da sync SSL certificates!"
    echo ""
}

#------------------------------------------------------------------------------
# Create HTTP vhost config
#------------------------------------------------------------------------------

create_http_vhost() {
    local domain=$1

    cat > "/var/server/nginx/conf/sites-available/$domain.conf" << EOF
server {
    listen 80;
    listen [::]:80;
    server_name $domain www.$domain;
    root $WWW_DIR/$domain/public_html;
    index index.html index.htm index.php;

    access_log $WWW_DIR/$domain/logs/access.log;
    error_log $WWW_DIR/$domain/logs/error.log;

    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;

    location / {
        try_files \$uri \$uri/ =404;
    }

    location ~ \.php\$ {
        fastcgi_pass unix:/run/php/php8.3-fpm.sock;
        fastcgi_param SCRIPT_FILENAME \$document_root\$fastcgi_script_name;
        include fastcgi_params;
    }

    location ~ /\. {
        deny all;
    }
}
EOF

    if [[ ! -L "/var/server/nginx/conf/sites-enabled/$domain.conf" ]]; then
        ln -sf "/var/server/nginx/conf/sites-available/$domain.conf" "/var/server/nginx/conf/sites-enabled/$domain.conf"
    fi

    chmod 644 "/var/server/nginx/conf/sites-available/$domain.conf"
}

#------------------------------------------------------------------------------
# Create SSL vhost config
#------------------------------------------------------------------------------

create_ssl_vhost() {
    local domain=$1

    cat > "/var/server/nginx/conf/sites-available/$domain.conf" << EOF
server {
    listen 80;
    listen [::]:80;
    server_name $domain www.$domain;
    return 301 https://\$host\$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name $domain www.$domain;

    root $WWW_DIR/$domain/public_html;
    index index.html index.htm index.php;

    ssl_certificate $WWW_DIR/$domain/ssl/fullchain.pem;
    ssl_certificate_key $WWW_DIR/$domain/ssl/privkey.pem;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    access_log $WWW_DIR/$domain/logs/access.log;
    error_log $WWW_DIR/$domain/logs/error.log;

    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-SSL-Protocol \$ssl_protocol always;

    location / {
        try_files \$uri \$uri/ =404;
    }

    location ~ \.php\$ {
        fastcgi_pass unix:/run/php/php8.3-fpm.sock;
        fastcgi_param SCRIPT_FILENAME \$document_root\$fastcgi_script_name;
        include fastcgi_params;
    }

    location ~ /\. {
        deny all;
    }
}
EOF

    if [[ ! -L "/var/server/nginx/conf/sites-enabled/$domain.conf" ]]; then
        ln -sf "/var/server/nginx/conf/sites-available/$domain.conf" "/var/server/nginx/conf/sites-enabled/$domain.conf"
    fi

    chmod 644 "/var/server/nginx/conf/sites-available/$domain.conf"
}

#------------------------------------------------------------------------------
# Update existing vhost to SSL
#------------------------------------------------------------------------------

update_vhost_ssl() {
    local domain=$1

    if [[ -f "/var/server/nginx/conf/sites-available/$domain.conf" ]]; then
        local has_ssl=$(grep -c "ssl_certificate" "/var/server/nginx/conf/sites-available/$domain.conf" 2>/dev/null || echo "0")

        if [[ "$has_ssl" -eq "0" ]]; then
            log_info "Cap nhat vhost len SSL cho $domain"
            create_ssl_vhost "$domain"
        fi
    fi
}

#------------------------------------------------------------------------------
# Sync all (domains + SSL)
#------------------------------------------------------------------------------

sync_all() {
    local ssh_cmd=$(build_ssh_cmd)

    echo ""
    log_info "Bat dau sync all..."

    sync_domains
    sync_ssl

    /usr/local/openresty/nginx/sbin/nginx -t 2>/dev/null && pkill nginx 2>/dev/null || true
    sleep 1
    /usr/local/openresty/nginx/sbin/nginx -c /var/server/nginx/conf/nginx.conf

    echo ""
    log_info "Da sync tat ca (domains + SSL)!"
    echo ""
}

#------------------------------------------------------------------------------
# Interactive select server
#------------------------------------------------------------------------------

interactive_select() {
    local action=$1
    local count=$(get_server_count)

    if [[ $count -eq 0 ]]; then
        log_warn "Chua co server nao"
        echo ""
        echo "Su dung: v-sync-config add"
        echo ""
        return 1
    fi

    list_servers

    printf "Nhap so thu tu: "
    read -r num

    if [[ -z "$num" ]] || [[ ! "$num" =~ ^[0-9]+$ ]]; then
        log_error "Vui long nhap so"
        return 1
    fi

    if [[ $num -lt 1 ]] || [[ $num -gt $count ]]; then
        log_error "So thu tu khong hop le (1-$count)"
        return 1
    fi

    if ! get_server_by_number "$num"; then
        log_error "Khong the lay thong tin server"
        return 1
    fi

    echo ""
    echo "Server: $SYNC_NAME ($SYNC_HOST)"
    echo ""

    case "$action" in
        list)
            list_remote_domains
            ;;
        domains)
            sync_domains
            ;;
        ssl)
            sync_ssl
            ;;
        all)
            sync_all
            ;;
    esac
}

#------------------------------------------------------------------------------
# MAIN
#------------------------------------------------------------------------------

main() {
    check_root
    init_config

    local action=""
    local server_name=""
    local server_id=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            list|domains|ssl|all)
                action="$1"
                ;;
            --name)
                server_name="$2"
                shift
                ;;
            --id)
                server_id="$2"
                shift
                ;;
            -h|--help)
                usage
                ;;
            *)
                log_error "Tuy chon khong hop le: $1"
                usage
                ;;
        esac
        shift
    done

    if [[ -z "$action" ]]; then
        usage
    fi

    print_header

    # Load server config
    if [[ -n "$server_id" ]]; then
        if ! get_server_by_number "$server_id"; then
            log_error "Server #$server_id khong ton tai"
            exit 1
        fi
    elif [[ -n "$server_name" ]]; then
        if ! get_server_config "$server_name"; then
            log_error "Server '$server_name' khong ton tai"
            echo ""
            echo "Su dung: v-sync-config add"
            exit 1
        fi
    else
        interactive_select "$action"
        return
    fi

    echo ""
    echo "Server: $SYNC_NAME ($SYNC_HOST)"
    echo ""

    case "$action" in
        list)
            list_remote_domains
            ;;
        domains)
            sync_domains
            ;;
        ssl)
            sync_ssl
            ;;
        all)
            sync_all
            ;;
    esac
}

main "$@"