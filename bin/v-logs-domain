#!/bin/bash
#==============================================================================
# v-logs-domain
# Xem logs cua domain - ho tro tail realtime
#==============================================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'
BOLD='\033[1m'

WWW_DIR="/var/www"
SPANEL_DIR="${SPANEL_DIR:-/var/server}"

#------------------------------------------------------------------------------
# Usage
#------------------------------------------------------------------------------
usage() {
    echo -e "${BLUE}v-logs-domain - Xem logs domain${NC}"
    echo ""
    echo -e "Usage: ${GREEN}v-logs-domain${NC} ${CYAN}<domain|all>${NC} [access|error|all] [-f]"
    echo ""
    echo "  domain      ten domain (hoac 'all' de xem tat ca)"
    echo "  access      chi hien thi access.log (mac dinh)"
    echo "  error       chi hien thi error.log"
    echo "  all         hien thi ca access.log va error.log"
    echo "  -f          follow mode (tail -f), bat tat bang Ctrl+C"
    echo ""
    echo "Examples:"
    echo "  v-logs-domain example.com           Xem access.log cua example.com"
    echo "  v-logs-domain example.com access    Xem access.log cua example.com"
    echo "  v-logs-domain example.com error     Xem error.log cua example.com"
    echo "  v-logs-domain example.com all       Xem ca access.log va error.log"
    echo "  v-logs-domain example.com -f        Follow access.log realtime"
    echo "  v-logs-domain all                   Xem tat ca access.logs"
    echo "  v-logs-domain all error             Xem tat ca error.logs"
    echo ""
    echo "Shortcuts:"
    echo "  v-logs-domain example.com a         = access"
    echo "  v-logs-domain example.com e        = error"
    echo "  v-logs-domain example.com f         = follow"
}

#------------------------------------------------------------------------------
# List domains with logs
#------------------------------------------------------------------------------
list_domains() {
    local count=0
    local domains=()

    for dir in "$WWW_DIR"/*/; do
        if [[ -d "$dir" ]]; then
            local name=$(basename "$dir")
            local has_access=0
            local has_error=0

            [[ -f "$dir/logs/access.log" ]] && has_access=1
            [[ -f "$dir/logs/error.log" ]] && has_error=1

            if [[ $has_access -eq 1 ]] || [[ $has_error -eq 1 ]]; then
                domains+=("$name")
                ((count++))
            fi
        fi
    done

    if [[ $count -eq 0 ]]; then
        echo -e "${YELLOW}Khong co domain nao co logs${NC}"
        return 1
    fi

    echo -e "${BLUE}Danh sach domains co logs:${NC}"
    echo ""
    for ((i=0; i<${#domains[@]}; i++)); do
        local name="${domains[$i]}"
        local access_mark=""
        local error_mark=""

        [[ -f "$WWW_DIR/$name/logs/access.log" ]] && access_mark="${GREEN}A${NC}"
        [[ -f "$WWW_DIR/$name/logs/error.log" ]] && error_mark="${RED}E${NC}"

        echo -e "  ${GREEN}$((i+1))${NC}) $name  [${access_mark}|${error_mark}]"
    done
    echo ""

    return 0
}

#------------------------------------------------------------------------------
# Get log content
#------------------------------------------------------------------------------
show_log() {
    local domain="$1"
    local log_type="$2"
    local follow="$3"
    local lines="${4:-50}"

    local log_dir="$WWW_DIR/$domain/logs"

    if [[ ! -d "$log_dir" ]]; then
        echo -e "${RED}Khong tim thay logs cho domain: $domain${NC}"
        return 1
    fi

    case "$log_type" in
        access|a)
            if [[ -f "$log_dir/access.log" ]]; then
                echo -e "${CYAN}=== $domain - access.log (last $lines lines) ===${NC}"
                if [[ "$follow" == "1" ]]; then
                    tail -f -n 50 "$log_dir/access.log"
                else
                    tail -n "$lines" "$log_dir/access.log"
                fi
            else
                echo -e "${YELLOW}Khong co access.log cho $domain${NC}"
            fi
            ;;
        error|e)
            if [[ -f "$log_dir/error.log" ]]; then
                echo -e "${RED}=== $domain - error.log (last $lines lines) ===${NC}"
                if [[ "$follow" == "1" ]]; then
                    tail -f -n 50 "$log_dir/error.log"
                else
                    tail -n "$lines" "$log_dir/error.log"
                fi
            else
                echo -e "${YELLOW}Khong co error.log cho $domain${NC}"
            fi
            ;;
        all)
            if [[ -f "$log_dir/access.log" ]]; then
                echo -e "${CYAN}=== $domain - access.log (last $lines lines) ===${NC}"
                tail -n "$lines" "$log_dir/access.log"
                echo ""
            fi
            if [[ -f "$log_dir/error.log" ]]; then
                echo -e "${RED}=== $domain - error.log (last $lines lines) ===${NC}"
                tail -n "$lines" "$log_dir/error.log"
            fi
            ;;
        *)
            # Default to access
            if [[ -f "$log_dir/access.log" ]]; then
                echo -e "${CYAN}=== $domain - access.log (last $lines lines) ===${NC}"
                if [[ "$follow" == "1" ]]; then
                    tail -f -n 50 "$log_dir/access.log"
                else
                    tail -n "$lines" "$log_dir/access.log"
                fi
            else
                echo -e "${YELLOW}Khong co access.log cho $domain${NC}"
            fi
            ;;
    esac
}

#------------------------------------------------------------------------------
# Show all domains logs
#------------------------------------------------------------------------------
show_all_logs() {
    local log_type="$1"
    local follow="$2"

    for dir in "$WWW_DIR"/*/; do
        if [[ -d "$dir" ]]; then
            local name=$(basename "$dir")
            local log_dir="$dir/logs"

            if [[ -d "$log_dir" ]]; then
                local has_logs=0

                if [[ "$log_type" == "access" ]] || [[ "$log_type" == "all" ]] || [[ "$log_type" == "" ]]; then
                    if [[ -f "$log_dir/access.log" ]]; then
                        has_logs=1
                        echo -e "${CYAN}=== $name - access.log ===${NC}"
                        tail -n 20 "$log_dir/access.log" 2>/dev/null
                        echo ""
                    fi
                fi

                if [[ "$log_type" == "error" ]] || [[ "$log_type" == "all" ]]; then
                    if [[ -f "$log_dir/error.log" ]]; then
                        has_logs=1
                        echo -e "${RED}=== $name - error.log ===${NC}"
                        tail -n 20 "$log_dir/error.log" 2>/dev/null
                        echo ""
                    fi
                fi

                [[ $has_logs -eq 1 ]] && echo "─────────────────────────────────────────"
            fi
        fi
    done
}

#------------------------------------------------------------------------------
# Format log line (for better readability)
#------------------------------------------------------------------------------
format_log_line() {
    local line="$1"
    local log_type="$2"

    if [[ "$log_type" == "access" ]]; then
        # Parse common log format: ip - - [date:time +zone] "method uri proto" status size "ref" "ua"
        local ip=$(echo "$line" | awk '{print $1}')
        local date=$(echo "$line" | grep -oP '\[\K[^\]]+')
        local method=$(echo "$line" | grep -oP '"[A-Z]+')
        local uri=$(echo "$line" | grep -oP '" [A-Z]+ \K[^\"]+')
        local status=$(echo "$line" | grep -oP '" [0-9]{3}' | tail -1 | tr -d '" ')
        local size=$(echo "$line" | awk '{print $NF}')

        # Color by status
        local status_color="$NC"
        if [[ "$status" =~ ^2 ]]; then
            status_color="$GREEN"
        elif [[ "$status" =~ ^3 ]]; then
            status_color="$YELLOW"
        elif [[ "$status" =~ ^4 ]]; then
            status_color="$RED"
        elif [[ "$status" =~ ^5 ]]; then
            status_color="${RED}"
        fi

        echo -e "${CYAN}$ip${NC} ${date} ${YELLOW}$method${NC} $uri ${status_color}$status${NC} $size"
    else
        echo "$line"
    fi
}

#------------------------------------------------------------------------------
# Interactive menu
#------------------------------------------------------------------------------
interactive() {
    echo -e "${BLUE}=== v-logs-domain - Chon domain ===${NC}"
    echo ""

    local domains=()
    local count=0

    for dir in "$WWW_DIR"/*/; do
        if [[ -d "$dir" ]]; then
            local name=$(basename "$dir")
            domains+=("$name")
            ((count++))
        fi
    done

    if [[ $count -eq 0 ]]; then
        echo -e "${RED}Khong co domain nao${NC}"
        return
    fi

    echo "  0) Tat ca domains"
    for ((i=0; i<count; i++)); do
        echo -e "  ${GREEN}$((i+1))${NC}) ${domains[$i]}"
    done
    echo ""

    read -p "Chon domain [0-$count]: " choice

    if [[ "$choice" == "0" ]]; then
        echo ""
        echo "  1) Access logs"
        echo "  2) Error logs"
        echo "  3) Tat ca"
        read -p "Chon loai log [1-3]: " log_choice

        case "$log_choice" in
            1) show_all_logs "access" ;;
            2) show_all_logs "error" ;;
            3) show_all_logs "all" ;;
        esac
    elif [[ "$choice" =~ ^[0-9]+$ ]] && [[ "$choice" -ge 1 ]] && [[ "$choice" -le "$count" ]]; then
        local domain="${domains[$((choice-1))]}"

        echo ""
        echo "  1) Access log"
        echo "  2) Error log"
        echo "  3) Tat ca"
        echo "  f) Follow mode (Ctrl+C de thoat)"
        read -p "Chon [1-3, f]: " log_choice

        local log_type="access"
        local follow=0

        case "$log_choice" in
            1) log_type="access" ;;
            2) log_type="error" ;;
            3) log_type="all" ;;
            f|F) log_type="access"; follow=1 ;;
            *) log_type="access" ;;
        esac

        echo ""
        show_log "$domain" "$log_type" "$follow"
    fi
}

#------------------------------------------------------------------------------
# Main
#------------------------------------------------------------------------------
main() {
    local domain=""
    local log_type=""
    local follow=0
    local interactive_mode=1

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                usage
                exit 0
                ;;
            -f|--follow)
                follow=1
                ;;
            all|a)
                domain="all"
                interactive_mode=0
                ;;
            access|a)
                log_type="access"
                ;;
            error|e)
                log_type="error"
                ;;
            *)
                if [[ -z "$domain" ]] || [[ "$domain" == "all" ]]; then
                    domain="$1"
                    interactive_mode=0
                else
                    log_type="$1"
                fi
                ;;
        esac
        shift
    done

    # Interactive mode if no args
    if [[ $interactive_mode -eq 1 ]]; then
        if [[ -t 0 ]] && [[ -z "$domain" ]]; then
            interactive
        else
            usage
        fi
        exit 0
    fi

    # Execute
    if [[ "$domain" == "all" ]]; then
        show_all_logs "$log_type" "$follow"
    else
        if [[ -z "$log_type" ]]; then
            log_type="access"
        fi
        show_log "$domain" "$log_type" "$follow"
    fi
}

main "$@"