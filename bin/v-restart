#!/bin/bash
#==============================================================================
# v-restart
# Restart all SPanel related services
#==============================================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_step() { echo -e "${BLUE}[STEP]${NC} $1"; }

# SPanel directories
SPANEL_DIR="${SPANEL_DIR:-/var/server}"
OPENRESTY_DIR="${OPENRESTY_DIR:-/usr/local/openresty}"
NGINX_BIN="$OPENRESTY_DIR/nginx/sbin/nginx"
NGINX_CONF="$SPANEL_DIR/nginx/conf/nginx.conf"
NGINX_DEFAULT_CONF="$OPENRESTY_DIR/nginx/conf/nginx.conf"

#------------------------------------------------------------------------------
# Print header
#------------------------------------------------------------------------------

print_header() {
    echo ""
    echo -e "${CYAN}╔════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║         SPanel - Restart Services           ║${NC}"
    echo -e "${CYAN}╚════════════════════════════════════════════╝${NC}"
    echo ""
}

#------------------------------------------------------------------------------
# Check root
#------------------------------------------------------------------------------

check_root() {
    if [[ $EUID -ne 0 ]]; then
        log_error "Can chay voi quyen root"
        exit 1
    fi
}

#------------------------------------------------------------------------------
# Stop all services
#------------------------------------------------------------------------------

stop_services() {
    log_step "Dang dung cac dich vu..."

    # Nginx / OpenResty
    if pgrep -x nginx > /dev/null 2>&1; then
        log_info "Dung Nginx..."
        "$NGINX_BIN" -s stop 2>/dev/null || true
        sleep 1
        pkill -9 nginx 2>/dev/null || true
        sleep 1
    fi

    # Redis
    if systemctl is-active --quiet redis-server 2>/dev/null; then
        log_info "Dung Redis..."
        systemctl stop redis-server 2>/dev/null || true
    fi

    # CrowdSec
    if systemctl is-active --quiet crowdsec 2>/dev/null; then
        log_info "Dung CrowdSec..."
        systemctl stop crowdsec 2>/dev/null || true
    fi

    log_info "Da dung tat ca dich vu"
}

#------------------------------------------------------------------------------
# Start all services
#------------------------------------------------------------------------------

start_services() {
    log_step "Dang khoi dong cac dich vu..."

    # Nginx / OpenResty
    if [[ -x "$NGINX_BIN" ]]; then
        log_info "Khoi dong Nginx..."

        # Thử SPanel config trước, fallback sang default
        if "$NGINX_BIN" -t -c "$NGINX_CONF" 2>/dev/null; then
            "$NGINX_BIN" -c "$NGINX_CONF"
        elif "$NGINX_BIN" -t -c "$NGINX_DEFAULT_CONF" 2>/dev/null; then
            log_warn "Dung cau hinh mac dinh thay vi SPanel config"
            "$NGINX_BIN" -c "$NGINX_DEFAULT_CONF"
        else
            log_error "Nginx config loi, khong khoi dong duoc"
            return 1
        fi

        sleep 1
        if pgrep -x nginx > /dev/null 2>&1; then
            log_info "Nginx da khoi dong"
            # Write PID file
            pgrep -x nginx | head -1 > "$SPANEL_DIR/run/nginx.pid" 2>/dev/null || true
        else
            log_error "Nginx khong the khoi dong"
        fi
    else
        log_warn "Nginx chua cai dat tai $NGINX_BIN"
    fi

    # Redis
    if command -v redis-server > /dev/null 2>&1; then
        log_info "Khoi dong Redis..."
        systemctl start redis-server 2>/dev/null || redis-server --daemonize yes 2>/dev/null || true
        if systemctl is-active --quiet redis-server 2>/dev/null || pgrep redis-server > /dev/null 2>&1; then
            log_info "Redis da khoi dong"
        fi
    fi

    # CrowdSec
    if [[ -f /etc/systemd/system/crowdsec.service ]]; then
        log_info "Khoi dong CrowdSec..."
        systemctl start crowdsec 2>/dev/null || true
        if systemctl is-active --quiet crowdsec 2>/dev/null; then
            log_info "CrowdSec da khoi dong"
        fi
    fi

    log_info "Da khoi dong tat ca dich vu"
}

#------------------------------------------------------------------------------
# Show status
#------------------------------------------------------------------------------

show_status() {
    echo ""
    echo -e "${YELLOW}Trang thai dich vu:${NC}"
    echo ""

    # Nginx
    if pgrep -x nginx > /dev/null 2>&1; then
        echo -e "  ${GREEN}[OK]${NC} Nginx"
    else
        echo -e "  ${RED}[FAIL]${NC} Nginx"
    fi

    # Redis
    if systemctl is-active --quiet redis-server 2>/dev/null; then
        echo -e "  ${GREEN}[OK]${NC} Redis"
    elif pgrep redis-server > /dev/null 2>&1; then
        echo -e "  ${GREEN}[OK]${NC} Redis (standalone)"
    else
        echo -e "  ${RED}[FAIL]${NC} Redis"
    fi

    # CrowdSec
    if systemctl is-active --quiet crowdsec 2>/dev/null; then
        echo -e "  ${GREEN}[OK]${NC} CrowdSec"
    else
        echo -e "  ${YELLOW}[OFF]${NC} CrowdSec"
    fi

    # Port check
    echo ""
    echo -e "${YELLOW}Port listening:${NC}"
    local ports=$(ss -tlnp 2>/dev/null | grep -E ":80|:443" | awk '{print $4}' | sort -u)
    if [[ -n "$ports" ]]; then
        echo "$ports" | while read port; do
            echo -e "  ${GREEN}[✓]${NC} $port"
        done
    else
        echo -e "  ${RED}[✗]${NC} Khong co port nao dang lang nghe"
    fi
}

#------------------------------------------------------------------------------
# Main
#------------------------------------------------------------------------------

main() {
    print_header

    check_root

    local action="${1:-restart}"

    case "$action" in
        restart|start|stop|status|reload-only)
            ;;
        *)
            echo "Usage: v-restart [restart|start|stop|status|reload-only]"
            echo ""
            echo "  restart     - Restart all services (default)"
            echo "  start       - Start all services"
            echo "  stop        - Stop all services"
            echo "  status      - Show service status"
            echo "  reload-only - Reload nginx config only"
            exit 1
            ;;
    esac

    if [[ "$action" == "stop" ]]; then
        stop_services
    elif [[ "$action" == "start" ]]; then
        start_services
    elif [[ "$action" == "reload-only" ]]; then
        log_info "Reload nginx..."
        if pgrep -x nginx > /dev/null 2>&1; then
            # Ensure PID file is valid
            local pid=$(pgrep -x nginx | head -1)
            if [[ -n "$pid" ]]; then
                echo "$pid" > "$SPANEL_DIR/run/nginx.pid" 2>/dev/null || true
            fi
            /usr/local/openresty/nginx/sbin/nginx -c "$NGINX_CONF" -s reload 2>/dev/null && log_info "Nginx da reload" || log_error "Loi reload Nginx"
        else
            log_error "Nginx khong dang chay"
        fi
    elif [[ "$action" == "status" ]]; then
        show_status
    else
        stop_services
        echo ""
        start_services
        show_status
    fi

    echo ""
}

main "$@"