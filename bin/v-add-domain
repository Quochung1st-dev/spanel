#!/bin/bash
#==============================================================================
# v-add-domain
# Thêm domain mới vào SPanel
#==============================================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

SPANEL_DIR="${SPANEL_DIR:-/var/server}"
WWW_DIR="/var/www"
NGINX_CONF="$SPANEL_DIR/nginx/conf"

#------------------------------------------------------------------------------
# Print header
#------------------------------------------------------------------------------

print_header() {
    echo ""
    echo -e "${BLUE}╔════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║       SPanel - Add Domain               ║${NC}"
    echo -e "${BLUE}╚════════════════════════════════════════╝${NC}"
}

#------------------------------------------------------------------------------
# Check root
#------------------------------------------------------------------------------

check_root() {
    if [[ $EUID -ne 0 ]]; then
        log_error "Can chay voi quyen root"
        exit 1
    fi
}

#------------------------------------------------------------------------------
# Usage
#------------------------------------------------------------------------------

usage() {
    echo ""
    echo "Usage: v-add-domain <domain> [options]"
    echo ""
    echo "Options:"
    echo "  --ssl           Kich hoat SSL (self-signed)"
    echo "  --letsencrypt   Kich hoat SSL (Let's Encrypt)"
    echo "  --proxy URL     Proxy den URL (VD: https://example.com)"
    echo ""
    echo "Examples:"
    echo "  v-add-domain example.com"
    echo "  v-add-domain example.com --ssl"
    echo "  v-add-domain example.com --ssl --proxy https://target.com"
    exit 1
}

#------------------------------------------------------------------------------
# Create domain directories
#------------------------------------------------------------------------------

create_dirs() {
    local domain=$1

    log_info "Tao cau truc thu muc..."

    mkdir -p "$WWW_DIR/$domain/public_html"
    mkdir -p "$WWW_DIR/$domain/logs"
    mkdir -p "$WWW_DIR/$domain/config"
    mkdir -p "$WWW_DIR/$domain/ssl"

    # Default index.html
    cat > "$WWW_DIR/$domain/public_html/index.html" << 'EOF'
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Welcome</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 40px; text-align: center; }
        h1 { color: #333; }
        .info { color: #666; margin-top: 20px; }
    </style>
</head>
<body>
    <h1>Welcome to your new website!</h1>
    <p class="info">This is the default page for SPanel.</p>
</body>
</html>
EOF

    log_info "Da tao thu muc"
}

#------------------------------------------------------------------------------
# Create nginx config
#------------------------------------------------------------------------------

create_vhost() {
    local domain=$1
    local enable_ssl=$2

    log_info "Tao nginx config..."

    local conf_file="$WWW_DIR/$domain/config/$domain.conf"

    if [[ "$enable_ssl" == "yes" ]]; then
        cat > "$conf_file" << 'EOF'
server {
    listen 80;
    listen [::]:80;
    server_name SERVER_DOMAIN SERVER_WWW;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name SERVER_DOMAIN SERVER_WWW;

    root WWW_DIR/public_html;
    index index.html index.htm index.php;

    ssl_certificate WWW_DIR/ssl/fullchain.pem;
    ssl_certificate_key WWW_DIR/ssl/privkey.pem;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    access_log WWW_DIR/logs/access.log;
    error_log WWW_DIR/logs/error.log;

    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-SSL-Protocol $ssl_protocol always;

    location / {
        try_files $uri $uri/ =404;
    }

    location ~ \.php$ {
        fastcgi_pass unix:/run/php/php8.3-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;
    }

    location ~ /\. {
        deny all;
    }
}
EOF

        sed -i "s|SERVER_DOMAIN|$domain|g" "$conf_file"
        sed -i "s|SERVER_WWW|www.$domain|g" "$conf_file"
        sed -i "s|WWW_DIR|$WWW_DIR/$domain|g" "$conf_file"
    else
        cat > "$conf_file" << 'EOF'
server {
    listen 80;
    listen [::]:80;
    server_name SERVER_DOMAIN SERVER_WWW;
    root WWW_DIR/public_html;
    index index.html index.htm index.php;

    access_log WWW_DIR/logs/access.log;
    error_log WWW_DIR/logs/error.log;

    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;

    location / {
        try_files $uri $uri/ =404;
    }

    location ~ \.php$ {
        fastcgi_pass unix:/run/php/php8.3-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;
    }

    location ~ /\. {
        deny all;
    }
}
EOF

        sed -i "s|SERVER_DOMAIN|$domain|g" "$conf_file"
        sed -i "s|SERVER_WWW|www.$domain|g" "$conf_file"
        sed -i "s|WWW_DIR|$WWW_DIR/$domain|g" "$conf_file"
    fi

    chmod 644 "$conf_file"

    # Config se duoc load truc tiep tu /var/www/$domain/config/
    # Khong can symlink nua vi nginx include /var/www/*/config/*.conf

    log_info "Da tao config"
}

#------------------------------------------------------------------------------
# Create proxy nginx config
#------------------------------------------------------------------------------

create_proxy_vhost() {
    local domain=$1
    local target_url=$2

    log_info "Tao proxy nginx config..."

    local conf_file="$WWW_DIR/$domain/config/$domain.conf"

    # Extract host from URL
    local target_host=$(echo "$target_url" | sed -e 's|https://||' -e 's|http://||' -e 's|/.*||')

    cat > "$conf_file" << EOF
server {
    listen 80;
    listen [::]:80;
    server_name $domain www.$domain;
    return 301 $target_url\$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name $domain www.$domain;

    ssl_certificate $WWW_DIR/$domain/ssl/fullchain.pem;
    ssl_certificate_key $WWW_DIR/$domain/ssl/privkey.pem;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    # Enable cache
    proxy_cache spanel_cache;
    proxy_cache_valid 200 5m;
    proxy_cache_valid 404 1m;
    proxy_cache_key "\$scheme\$host\$request_uri";
    add_header X-Cache-Status \$upstream_cache_status always;
    proxy_no_cache \$skip_cache;
    proxy_cache_bypass \$skip_cache;

    # Force cache ignoring origin headers
    proxy_ignore_headers Cache-Control Expires Set-Cookie X-Accel-Expires;

    # Buffer settings
    proxy_buffering on;
    proxy_buffer_size 4k;
    proxy_buffers 24 4k;
    proxy_busy_buffers_size 8k;

    # Proxy to target
    location / {
        proxy_pass $target_url;
        proxy_ssl_server_name on;
        proxy_set_header Host $target_host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_connect_timeout 30s;
        proxy_read_timeout 30s;
        proxy_cache_valid 200 5m;
        proxy_cache_use_stale error timeout updating http_500 http_502 http_503 http_504;
        proxy_cache_min_uses 1;
    }

    # Static files cache longer
    location ~* \\.(jpg|jpeg|png|gif|ico|css|js|woff|woff2|ttf|svg|eot|otf)\$ {
        proxy_pass $target_url;
        proxy_ssl_server_name on;
        proxy_set_header Host $target_host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_cache_valid 200 30m;
        proxy_cache_use_stale error timeout updating invalid_header;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    access_log $WWW_DIR/$domain/logs/access.log;
    error_log $WWW_DIR/$domain/logs/error.log;
}
EOF

    chmod 644 "$conf_file"

    # Symlink to sites-available
    ln -sf "$conf_file" "$NGINX_CONF/sites-available/$domain.conf"

    log_info "Da tao proxy config"
}

#------------------------------------------------------------------------------
# Create SSL certificate
#------------------------------------------------------------------------------

create_ssl() {
    local domain=$1
    local ssl_type=$2

    log_info "Tao SSL certificate..."

    local cert_dir="$WWW_DIR/$domain/ssl"
    mkdir -p "$cert_dir"

    if [[ "$ssl_type" == "letsencrypt" ]]; then
        if command -v certbot &>/dev/null; then
            certbot certonly --webroot \
                --webroot-path "$WWW_DIR/$domain/public_html" \
                --domain "$domain" \
                --email "admin@$domain" \
                --agree-tos \
                --noninteractive 2>/dev/null || {
                log_warn "Let's Encrypt that bai, su dung self-signed"
                ssl_type="selfsigned"
            }
        else
            log_warn "Certbot khong co san"
            ssl_type="selfsigned"
        fi
    fi

    if [[ "$ssl_type" == "selfsigned" ]] || [[ ! -f "$cert_dir/fullchain.pem" ]]; then
        OPENSSL_CONF=/usr/lib/ssl/openssl.cnf \
        /usr/bin/openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
            -keyout "$cert_dir/privkey.pem" \
            -out "$cert_dir/fullchain.pem" \
            -subj "/C=VN/ST=HCM/L=HCM/O=SPanel/CN=$domain"
        log_info "Da tao self-signed certificate"
    fi
}

#------------------------------------------------------------------------------
# Reload nginx
#------------------------------------------------------------------------------

reload_nginx() {
    v-restart reload-only
}

#------------------------------------------------------------------------------
# Enable domain
#------------------------------------------------------------------------------

enable_domain() {
    local domain=$1

    log_info "Enable domain..."

    # Config is in /var/www/$domain/config/$domain.conf
    # Nginx loads it directly via include /var/www/*/config/*.conf

    # Test and reload nginx
    reload_nginx
}

#------------------------------------------------------------------------------
# Add domain
#------------------------------------------------------------------------------

add_domain() {
    local domain=$1
    local enable_ssl="no"
    local ssl_type="selfsigned"
    local proxy_url=""

    # Parse arguments
    shift
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --ssl)
                enable_ssl="yes"
                ssl_type="selfsigned"
                ;;
            --letsencrypt)
                enable_ssl="yes"
                ssl_type="letsencrypt"
                ;;
            --proxy)
                proxy_url="$2"
                enable_ssl="yes"
                shift
                ;;
            *)
                ;;
        esac
        shift
    done

    # Validate domain
    if [[ -z "$domain" ]]; then
        usage
    fi

    # Check if domain exists
    if [[ -d "$WWW_DIR/$domain" ]]; then
        log_error "Domain $domain da ton tai"
        exit 1
    fi

    # Check if config exists
    if [[ -f "$NGINX_CONF/sites-available/$domain.conf" ]]; then
        log_error "Config cho $domain da ton tai"
        exit 1
    fi

    print_header
    echo ""
    echo "Domain: $domain"
    echo "SSL: $enable_ssl"
    if [[ -n "$proxy_url" ]]; then
        echo "Proxy: $proxy_url"
    fi
    echo ""

    # Create
    create_dirs "$domain"

    if [[ "$enable_ssl" == "yes" ]]; then
        create_ssl "$domain" "$ssl_type"
    fi

    if [[ -n "$proxy_url" ]]; then
        create_proxy_vhost "$domain" "$proxy_url"
    else
        create_vhost "$domain" "$enable_ssl"
    fi

    # Always enable domain
    enable_domain "$domain"

    echo ""
    log_info "Da tao domain $domain thanh cong!"
    echo ""
    if [[ "$enable_ssl" == "yes" ]]; then
        echo "  SSL: $WWW_DIR/$domain/ssl"
        echo "  Cert: $WWW_DIR/$domain/ssl/fullchain.pem"
    fi
    if [[ -n "$proxy_url" ]]; then
        echo "  Proxy: $proxy_url"
        echo "  Cache: enabled"
    fi
    echo ""
}

#------------------------------------------------------------------------------
# MAIN
#------------------------------------------------------------------------------

main() {
    check_root

    if [[ $# -eq 0 ]]; then
        usage
    fi

    add_domain "$@"
}

main "$@"