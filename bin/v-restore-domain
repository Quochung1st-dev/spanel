#!/bin/bash
#==============================================================================
# v-restore-domain
# Khoi phuc domain tu backup
#==============================================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

SPANEL_DIR="${SPANEL_DIR:-/var/server}"
WWW_DIR="/var/www"
NGINX_CONF="$SPANEL_DIR/nginx/conf"
BACKUP_DIR="/var/backups"

#------------------------------------------------------------------------------
# Check root
#------------------------------------------------------------------------------

check_root() {
    if [[ $EUID -ne 0 ]]; then
        log_error "Can chay voi quyen root"
        exit 1
    fi
}

#------------------------------------------------------------------------------
# Print header
#------------------------------------------------------------------------------

print_header() {
    echo ""
    echo -e "${BLUE}╔════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║       SPanel - Restore Domain          ║${NC}"
    echo -e "${BLUE}╚════════════════════════════════════════╝${NC}"
}

#------------------------------------------------------------------------------
# Usage
#------------------------------------------------------------------------------

usage() {
    echo ""
    echo "Usage: v-restore-domain <domain> <backup_file> [options]"
    echo ""
    echo "Options:"
    echo "  --list     Danh sach backup hien co"
    echo ""
    echo "Examples:"
    echo "  v-restore-domain example.com /var/backups/example.com_20240101.tar.gz"
    echo "  v-restore-domain --list"
    exit 1
}

#------------------------------------------------------------------------------
# List backups
#------------------------------------------------------------------------------

list_backups() {
    echo ""
    echo -e "${BLUE}── Backup List ──${NC}"
    echo ""

    if [[ ! -d "$BACKUP_DIR" ]]; then
        echo "Khong co backup nao"
        return
    fi

    local count=0
    for f in "$BACKUP_DIR"/*.tar.gz; do
        [[ -f "$f" ]] || continue
        ((count++))
        local size=$(du -h "$f" | awk '{print $1}')
        local date=$(stat -c %y "$f" 2>/dev/null | cut -d' ' -f1 || date -r "$f" +%Y-%m-%d)
        echo "  $(basename "$f")"
        echo "    Size: $size | Date: $date"
    done

    echo ""
    echo "Total: $count backups"
    echo ""
}

#------------------------------------------------------------------------------
# Restore domain
#------------------------------------------------------------------------------

restore_domain() {
    local domain=$1
    local backup_file=$2

    if [[ -z "$domain" ]]; then
        log_error "Vui long nhap domain"
        return 1
    fi

    if [[ -z "$backup_file" ]]; then
        log_error "Vui long nhap duong dan backup"
        return 1
    fi

    if [[ ! -f "$backup_file" ]]; then
        log_error "File backup khong ton tai: $backup_file"
        return 1
    fi

    print_header
    echo ""
    echo "Domain: $domain"
    echo "Backup: $(basename "$backup_file")"
    echo ""

    # Xac nhan ghi de neu domain da ton tai
    if [[ -d "$WWW_DIR/$domain" ]]; then
        log_warn "Domain '$domain' da ton tai!"
        echo ""
        echo "  1. Ghi de (xoa du lieu cu, restore tu backup)"
        echo "  2. Huy"
        echo ""
        printf "  Chon [1-2]: "
        read -r choice
        case "$choice" in
            1)
                rm -rf "$WWW_DIR/$domain"
                log_info "Da xoa domain cu"
                ;;
            *)
                log_info "Da huy restore"
                return 0
                ;;
        esac
    fi

    # Giai nen backup vao thu muc domain
    log_info "Giai nen backup..."
    mkdir -p "$WWW_DIR/$domain"
    tar -xzf "$backup_file" -C "$WWW_DIR" 2>/dev/null

    if [[ ! -d "$WWW_DIR/$domain" ]]; then
        log_error "Giai nen that bai"
        return 1
    fi

    # Reload nginx (config from /var/www/$domain/config/ is loaded automatically)
    v-restart reload-only 2>/dev/null || true

    echo ""
    log_info "Khoi phuc thanh cong!"
    echo ""
    echo "  Domain: $domain"
    echo "  Root: $WWW_DIR/$domain/public_html"
    local conf_target="$WWW_DIR/$domain/config/$domain.conf"
    if [[ -f "$conf_target" ]]; then
        echo "  Config: $conf_target"
    fi
    echo ""
}

#------------------------------------------------------------------------------
# MAIN
#------------------------------------------------------------------------------

main() {
    check_root

    if [[ $# -eq 0 ]]; then
        usage
    fi

    local domain=""
    local backup_file=""

    for arg in "$@"; do
        case "$arg" in
            --list)
                list_backups
                exit 0
                ;;
            -h|--help)
                usage
                ;;
            *)
                if [[ -z "$domain" ]]; then
                    domain="$arg"
                elif [[ -z "$backup_file" ]]; then
                    backup_file="$arg"
                fi
                ;;
        esac
    done

    restore_domain "$domain" "$backup_file"
}

main "$@"
