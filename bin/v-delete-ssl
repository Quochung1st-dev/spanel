#!/bin/bash
#==============================================================================
# v-delete-ssl
# Xoa SSL certificate cua domain
#==============================================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

WWW_DIR="/var/www"
NGINX_CONF="/var/server/nginx/conf"

#------------------------------------------------------------------------------
# Check root
#------------------------------------------------------------------------------

check_root() {
    if [[ $EUID -ne 0 ]]; then
        log_error "Can chay voi quyen root"
        exit 1
    fi
}

#------------------------------------------------------------------------------
# Print header
#------------------------------------------------------------------------------

print_header() {
    echo ""
    echo -e "${BLUE}╔════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║       SPanel - Delete SSL               ║${NC}"
    echo -e "${BLUE}╚════════════════════════════════════════╝${NC}"
}

#------------------------------------------------------------------------------
# Usage
#------------------------------------------------------------------------------

usage() {
    echo ""
    echo "Usage: v-delete-ssl <domain>"
    echo ""
    echo "Examples:"
    echo "  v-delete-ssl example.com"
    exit 1
}

#------------------------------------------------------------------------------
# Delete SSL certificate
#------------------------------------------------------------------------------

delete_ssl() {
    local domain=$1

    local cert_dir="$WWW_DIR/$domain/ssl"
    local conf_file="$NGINX_CONF/sites-available/$domain.conf"

    # Check domain exists
    if [[ ! -d "$WWW_DIR/$domain" ]]; then
        log_error "Domain '$domain' khong ton tai"
        return 1
    fi

    print_header
    echo ""
    echo "Domain: $domain"
    echo ""

    # Delete SSL certificates
    if [[ -d "$cert_dir" ]]; then
        log_info "Xoa SSL certificates..."
        rm -rf "$cert_dir"
        log_info "Da xoa SSL certificates"
    fi

    # Update nginx config to HTTP only
    if [[ -f "$conf_file" ]]; then
        log_info "Cap nhat nginx config (HTTP only)..."

        cat > "$conf_file" << EOF
server {
    listen 80;
    listen [::]:80;
    server_name $domain www.$domain;
    root $WWW_DIR/$domain/public_html;
    index index.html index.htm index.php;

    access_log $WWW_DIR/$domain/logs/access.log;
    error_log $WWW_DIR/$domain/logs/error.log;

    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;

    location / {
        try_files \$uri \$uri/ =404;
    }

    location ~ \.php\$ {
        fastcgi_pass unix:/run/php/php8.3-fpm.sock;
        fastcgi_param SCRIPT_FILENAME \$document_root\$fastcgi_script_name;
        include fastcgi_params;
    }

    location ~ /\. {
        deny all;
    }
}
EOF

        chmod 644 "$conf_file"
        log_info "Da chuyen ve HTTP"
    fi

    # Reload nginx
    if /usr/local/openresty/nginx/sbin/nginx -t 2>/dev/null; then
        pkill nginx 2>/dev/null || true
        sleep 1
        /usr/local/openresty/nginx/sbin/nginx -c /var/server/nginx/conf/nginx.conf
        log_info "Da reload nginx"
    fi

    echo ""
    log_info "Da xoa SSL cho $domain thanh cong!"
    echo ""
}

#------------------------------------------------------------------------------
# MAIN
#------------------------------------------------------------------------------

main() {
    check_root

    local domain="$1"

    if [[ -z "$domain" ]]; then
        usage
    fi

    delete_ssl "$domain"
}

main "$@"