#!/bin/bash
#==============================================================================
# v-list-domain
# Danh sách domain trong SPanel
#==============================================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'
BOLD='\033[1m'

WWW_DIR="/var/www"
SPANEL_DIR="${SPANEL_DIR:-/var/server}"

#------------------------------------------------------------------------------
# Header
#------------------------------------------------------------------------------

print_header() {
    echo ""
    echo -e "${BLUE}╔══════════════════════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║${NC}                   ${BOLD}SPanel - Domain List${NC}                                ${BLUE}║${NC}"
    echo -e "${BLUE}╚══════════════════════════════════════════════════════════════════════════════╝${NC}"
}

#------------------------------------------------------------------------------
# List all domains
#------------------------------------------------------------------------------

list_all() {
    local count=0
    local domains=()

    for dir in "$WWW_DIR"/*/; do
        if [[ -d "$dir" ]]; then
            local name=$(basename "$dir")
            domains+=("$name")
        fi
    done

    if [[ ${#domains[@]} -eq 0 ]]; then
        echo -e "${YELLOW}Khong co domain nao${NC}"
        return
    fi

    echo ""
    echo -e "  ${CYAN}#   Domain                      SSL    Size       Proxy${NC}"
    echo -e "  ${CYAN}──  ──────────────────────────  ────   ───────    ──────────────────${NC}"

    for ((i=0; i<${#domains[@]}; i++)); do
        local domain="${domains[$i]}"
        local conf="$WWW_DIR/$domain/config/$domain.conf"

        # Size
        local size=$(du -sh "$WWW_DIR/$domain" 2>/dev/null | awk '{print $1}' || echo "0")

        # SSL
        local ssl_mark="${RED}✗${NC}"
        if [[ -f "$WWW_DIR/$domain/ssl/fullchain.pem" ]] || [[ -f "$WWW_DIR/$domain/ssl/server.crt" ]]; then
            ssl_mark="${GREEN}✓${NC}"
        fi

        # Proxy target (from config)
        local proxy="—"
        if [[ -f "$conf" ]]; then
            local upstream=$(grep -oP 'proxy_ssl_name \K.*' "$conf" 2>/dev/null | head -1 | tr -d ';')
            if [[ -z "$upstream" ]]; then
                upstream=$(grep -oP 'proxy_set_header Host \K.*' "$conf" 2>/dev/null | head -1 | tr -d ';')
            fi
            [[ -n "$upstream" ]] && proxy="$upstream"
        fi

        printf "  ${GREEN}%2d)${NC} %-28s ${ssl_mark}     %-9s  %s\n" $((i+1)) "$domain" "$size" "$proxy"
        ((count++))
    done

    echo ""
    echo -e "  ${CYAN}──────────────────────────────────────────────────────────────────${NC}"
    echo -e "  Total: ${BOLD}${count}${NC} domains"
}

#------------------------------------------------------------------------------
# Detail domain
#------------------------------------------------------------------------------

show_detail() {
    local domain=$1
    local www_dir="$WWW_DIR/$domain"
    local conf="$www_dir/config/$domain.conf"

    if [[ -z "$domain" ]]; then
        echo -e "${RED}Usage: v-list-domain <domain>${NC}"
        return 1
    fi

    if [[ ! -d "$www_dir" ]]; then
        echo -e "${RED}Domain '$domain' khong ton tai${NC}"
        return 1
    fi

    echo ""
    echo -e "${BLUE}╔══════════════════════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║${NC}  ${BOLD}${domain}${NC}"
    echo -e "${BLUE}╚══════════════════════════════════════════════════════════════════════════════╝${NC}"
    echo ""

    # Config
    if [[ -f "$conf" ]]; then
        echo -e "  Config:     ${conf}"
    else
        echo -e "  Config:     ${RED}Khong tim thay${NC}"
    fi

    # Proxy / Upstream
    if [[ -f "$conf" ]]; then
        local upstream_host=$(grep -oP 'proxy_ssl_name \K.*' "$conf" 2>/dev/null | head -1)
        local upstream_ip=$(grep -oP 'proxy_pass https://\K[^:]+' "$conf" 2>/dev/null | head -1)

        if [[ -n "$upstream_host" ]]; then
            echo -e "  Proxy:      ${upstream_host} (${upstream_ip:-N/A})"
        fi
    fi

    # SSL
    local ssl_file=""
    if [[ -f "$www_dir/ssl/fullchain.pem" ]]; then
        ssl_file="$www_dir/ssl/fullchain.pem"
    elif [[ -f "$www_dir/ssl/server.crt" ]]; then
        ssl_file="$www_dir/ssl/server.crt"
    fi

    if [[ -n "$ssl_file" ]]; then
        local issuer=$(openssl x509 -in "$ssl_file" -noout -issuer 2>/dev/null | sed 's/issuer=//' || echo "N/A")
        local expiry=$(openssl x509 -in "$ssl_file" -noout -enddate 2>/dev/null | cut -d= -f2 || echo "N/A")
        echo -e "  SSL:        ${GREEN}Co${NC}  (Issuer: $issuer)"
        echo -e "  Expires:    $expiry"
    else
        echo -e "  SSL:        ${RED}Chua co${NC}"
    fi

    # Disk
    local total_size=$(du -sh "$www_dir" 2>/dev/null | awk '{print $1}')
    local log_size=$(du -sh "$www_dir/logs" 2>/dev/null | awk '{print $1}')
    local ssl_size=$(du -sh "$www_dir/ssl" 2>/dev/null | awk '{print $1}')
    echo ""
    echo -e "  Disk:       ${total_size}"
    echo -e "  Logs:       ${log_size}"
    echo -e "  SSL:        ${ssl_size}"

    # Cache
    local cache_dir="/var/cache/nginx/$domain"
    if [[ -d "$cache_dir" ]]; then
        local cache_size=$(du -sh "$cache_dir" 2>/dev/null | awk '{print $1}')
        local cache_files=$(find "$cache_dir" -type f 2>/dev/null | wc -l)
        echo -e "  Cache:      ${cache_size} (${cache_files} files)"
    fi

    # Logs
    echo ""
    if [[ -f "$www_dir/logs/access.log" ]]; then
        local log_lines=$(wc -l < "$www_dir/logs/access.log" 2>/dev/null || echo "0")
        echo -e "  Access log: ${log_lines} lines"
    fi
    if [[ -f "$www_dir/logs/error.log" ]]; then
        local err_lines=$(wc -l < "$www_dir/logs/error.log" 2>/dev/null || echo "0")
        echo -e "  Error log:  ${err_lines} lines"
    fi

    echo ""
}

#------------------------------------------------------------------------------
# MAIN
#------------------------------------------------------------------------------

main() {
    if [[ $EUID -ne 0 ]]; then
        echo -e "${RED}Can chay voi quyen root${NC}"
        exit 1
    fi

    print_header

    if [[ -n "$1" ]]; then
        show_detail "$1"
    else
        list_all
        echo ""
    fi
}

main "$@"
