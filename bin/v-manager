#!/bin/bash
#==============================================================================
# SPanel - Manager Menu
# Menu quan ly SPanel bang giao dien so
#==============================================================================

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
PURPLE='\033[0;35m'
WHITE='\033[1;37m'
NC='\033[0m'
BOLD='\033[1m'

# Check root
check_root() {
    if [[ $EUID -ne 0 ]]; then
        echo -e "${RED}Bạn cần chạy với quyền root${NC}"
        exit 1
    fi
}

# Get system info
get_cpu_usage() {
    top -bn1 | grep "Cpu(s)" | awk '{print int($2)}'% 2>/dev/null || echo "N/A"
}

get_cpu() {
    awk '/^cpu /{usage=($2+$4)*100/($2+$4+$5)} END{printf "%.0f",usage}' /proc/stat 2>/dev/null || echo "N/A"
}

get_ram() {
    free | awk '/^Mem:/ {printf "%.0f", $3/$2 * 100}' 2>/dev/null || echo "N/A"
}

get_ram_used() {
    free -m | awk '/^Mem:/ {printf "%s/%sMB", $3, $2}' 2>/dev/null || echo "N/A"
}

get_disk() {
    df -h / | awk 'NR==2 {print $5}' 2>/dev/null || echo "N/A"
}

get_uptime() {
    uptime -p 2>/dev/null || echo "N/A"
}

get_domain_count() {
    ls -d /var/www/*/ 2>/dev/null | wc -l || echo "0"
}

get_service_status() {
    local service=$1
    if systemctl is-active --quiet "$service" 2>/dev/null; then
        echo -e "${GREEN}ON${NC}"
    else
        echo -e "${RED}OFF${NC}"
    fi
}

get_load_avg() {
    uptime | awk -F'load average:' '{print $2}' | awk '{print $1,$2,$3}' 2>/dev/null || echo "N/A"
}

# Print header
print_header() {
    clear

    local hostname=$(hostname 2>/dev/null || echo "server")
    local ip=$(hostname -I 2>/dev/null | awk '{print $1}' || echo "N/A")
    local uptime_info=$(get_uptime)
    local domain_count=$(get_domain_count)
    local load=$(get_load_avg)

    # System resources
    local cpu=$(get_cpu)
    local ram=$(get_ram)
    local ram_info=$(get_ram_used)
    local disk=$(get_disk)

    # Color coding based on usage
    local cpu_color="$GREEN"
    [[ "$cpu" -gt 70 ]] && cpu_color="$RED"
    [[ "$cpu" -gt 50 && "$cpu" -le 70 ]] && cpu_color="$YELLOW"

    local ram_color="$GREEN"
    [[ "$ram" -gt 80 ]] && ram_color="$RED"
    [[ "$ram" -gt 60 && "$ram" -le 80 ]] && ram_color="$YELLOW"

    local disk_color="$GREEN"
    local disk_num="${disk%\%}"
    [[ "$disk_num" -gt 85 ]] && disk_color="$RED"
    [[ "$disk_num" -gt 70 && "$disk_num" -le 85 ]] && disk_color="$YELLOW"

    # Service status
    local nginx_st=$(get_service_status nginx)
    local redis_st=$(get_service_status redis-server)
    local crowdsec_st=$(get_service_status crowdsec)

    # Progress bar
    progress_bar() {
        local pct=$1
        local width=10
        local filled=$((pct * width / 100))
        local empty=$((width - filled))
        local bar=""
        for ((i=0; i<filled; i++)); do bar="${bar}#"; done
        for ((i=0; i<empty; i++)); do bar="${bar}-"; done
        echo "[$bar]"
    }

    echo -e "${BLUE}╔══════════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║${NC}              ${BOLD}${WHITE}SPanel - Quan ly Server${NC}                             ${BLUE}║${NC}"
    echo -e "${BLUE}╠══════════════════════════════════════════════════════════════════╣${NC}"
    echo -e "${BLUE}║${NC}  ${CYAN}Server:${NC} ${BOLD}${hostname}${NC} (${ip})"
    echo -e "${BLUE}║${NC}  ${CYAN}Uptime:${NC} ${uptime_info}"
    echo -e "${BLUE}╠══════════════════════════════════════════════════════════════════╣${NC}"
    echo -e "${BLUE}║${NC}  ${CYAN}CPU:${NC}  ${cpu_color}$(progress_bar "$cpu") ${cpu}%${NC}     ${CYAN}RAM:${NC}  ${ram_color}$(progress_bar "$ram") ${ram}% ${ram_info}${NC}"
    echo -e "${BLUE}║${NC}  ${CYAN}Disk:${NC} ${disk_color}$(progress_bar "$disk_num") ${disk}${NC}      ${CYAN}Load:${NC} ${load}"
    echo -e "${BLUE}╠══════════════════════════════════════════════════════════════════╣${NC}"
    echo -e "${BLUE}║${NC}  ${CYAN}Domains:${NC} ${BOLD}${domain_count}${NC}    ${CYAN}Nginx:${NC} ${nginx_st}  ${CYAN}Redis:${NC} ${redis_st}  ${CYAN}CrowdSec:${NC} ${crowdsec_st}"
    echo -e "${BLUE}╚══════════════════════════════════════════════════════════════════╝${NC}"
    echo ""
}

# Print footer
print_footer() {
    echo ""
    echo -e "${YELLOW}Nhan ${CYAN}[0]${YELLOW} de thoat${NC}"
    echo ""
}

# Pause function
pause() {
    echo ""
    read -p "Nhan Enter de tiep tuc..." key
}

# Check if command exists
cmd_exists() {
    command -v "$1" &>/dev/null
}

#==============================================================================
# Domain Management
#==============================================================================
menu_domain() {
    while true; do
        print_header
        echo -e "${CYAN}--- Quan ly Domain ---${NC}"
        echo ""
        echo "  1) Danh sach domain"
        echo "  2) Them domain moi"
        echo "  3) Tao domain tu template"
        echo "  4) Sua domain"
        echo "  5) Xoa domain"
        echo "  6) Rebuild domain"
        echo ""
        echo "  0) Quay lai"
        echo ""
        print_footer

        read -p "Chon so [0-6]: " choice

        case $choice in
            1)
                v-list-domain
                pause
                ;;
            2)
                read -p "Nhap domain: " domain
                if [[ -n "$domain" ]]; then
                    v-add-domain "$domain"
                fi
                pause
                ;;
            3)
                v-template-domain
                pause
                ;;
            4)
                echo ""
                read -p "Nhap domain can sua: " domain
                if [[ -n "$domain" ]]; then
                    v-change-domain "$domain"
                fi
                pause
                ;;
            5)
                read -p "Nhap domain can xoa: " domain
                if [[ -n "$domain" ]]; then
                    v-delete-domain "$domain"
                fi
                pause
                ;;
            6)
                read -p "Nhap domain can rebuild: " domain
                if [[ -n "$domain" ]]; then
                    v-rebuild-domain "$domain"
                fi
                pause
 ;;
            0)
                break
                ;;
            *)
                echo -e "${RED}Lua chon khong hop le${NC}"
                sleep 1
                ;;
        esac
    done
}

#==============================================================================
# SSL Management
#==============================================================================
menu_ssl() {
    while true; do
        print_header
        echo -e "${CYAN}--- Quan ly SSL ---${NC}"
        echo ""
        read -p "Nhap domain: " domain

        if [[ -z "$domain" ]]; then
            break
        fi

        echo ""
        echo "  1) Them SSL (Let's Encrypt)"
        echo "  2) Them SSL (Self-signed)"
        echo "  3) Xoa SSL"
        echo ""
        echo "  0) Quay lai"
        echo ""
        print_footer

        read -p "Chon so [0-3]: " choice

        case $choice in
            1)
                v-add-ssl "$domain" letssl
                pause
                ;;
            2)
                v-add-ssl "$domain" ssl
                pause
                ;;
            3)
                v-delete-ssl "$domain"
                pause
                ;;
            0)
                break
                ;;
            *)
                echo -e "${RED}Lua chon khong hop le${NC}"
                sleep 1
                ;;
        esac
    done
}

#==============================================================================
# WAF & IP Management
#==============================================================================
menu_waf() {
    while true; do
        print_header
        echo -e "${CYAN}--- Quan ly WAF & IP ---${NC}"
        echo ""
        echo "  === Blocklist ==="
        echo "  1) Danh sach Blocklist"
        echo "  2) Them IP vao Blocklist"
        echo "  3) Xoa IP khoi Blocklist"
        echo ""
        echo "  === Whitelist ==="
        echo "  4) Danh sach Whitelist"
        echo "  5) Them IP vao Whitelist"
        echo "  6) Xoa IP khoi Whitelist"
        echo ""
        echo "  0) Quay lai"
        echo ""
        print_footer

        read -p "Chon so [0-6]: " choice

        case $choice in
            1)
                v-list-blocklist
                pause
                ;;
            2)
                read -p "Nhap IP: " ip
                read -p "Ly do: " reason
                v-add-blocklist "$ip" "$reason"
                pause
                ;;
            3)
                read -p "Nhap IP can xoa: " ip
                v-delete-blocklist "$ip"
                pause
                ;;
            4)
                v-list-whitelist
                pause
                ;;
            5)
                read -p "Nhap IP: " ip
                read -p "Ly do: " reason
                v-add-whitelist "$ip" "$reason"
                pause
                ;;
            6)
                read -p "Nhap IP can xoa: " ip
                v-delete-whitelist "$ip"
                pause
                ;;
            0)
                break
                ;;
            *)
                echo -e "${RED}Lua chon khong hop le${NC}"
                sleep 1
                ;;
        esac
    done
}

# List domains with numbers
list_domains_numbered() {
    local count=0
    local domains=()

    for dir in /var/www/*/; do
        if [[ -d "$dir" ]]; then
            local name=$(basename "$dir")
            domains+=("$name")
        fi
    done

    if [[ ${#domains[@]} -eq 0 ]]; then
        echo -e "${RED}Khong co domain nao${NC}"
        return 1
    fi

    echo -e "${YELLOW}Danh sach domains:${NC}"
    echo ""
    for ((i=0; i<${#domains[@]}; i++)); do
        local ssl_mark=""
        if [[ -f "/var/www/${domains[$i]}/ssl/fullchain.pem" ]]; then
            ssl_mark=" ${GREEN}*${NC}"
        fi
        echo -e "  ${GREEN}$((i+1)))${NC} ${domains[$i]}${ssl_mark}"
    done
    echo ""

    # Return domains array via global
    DOMAINS_LIST=("${domains[@]}")
    return 0
}

#==============================================================================
# Backup & Restore
#==============================================================================
menu_backup() {
    while true; do
        print_header
        echo -e "${CYAN}--- Backup & Restore ---${NC}"
        echo ""
        echo "  1) Backup domain"
        echo "  2) Backup tat ca domain"
        echo "  3) Restore domain"
        echo "  4) Danh sach backup"
        echo ""
        echo "  0) Quay lai"
        echo ""
        print_footer

        read -p "Chon so [0-4]: " choice

        case $choice in
            1)
                print_header
                echo -e "${CYAN}--- Backup domain ---${NC}"
                echo ""
                list_domains_numbered
                if [[ $? -eq 0 ]]; then
                    read -p "Chon domain [1-${#DOMAINS_LIST[@]}]: " d_choice
                    if [[ "$d_choice" =~ ^[0-9]+$ ]] && [[ "$d_choice" -ge 1 ]] && [[ "$d_choice" -le "${#DOMAINS_LIST[@]}" ]]; then
                        v-backup-domain "${DOMAINS_LIST[$((d_choice-1))]}"
                    else
                        echo -e "${RED}Lua chon khong hop le${NC}"
                    fi
                fi
                pause
                ;;
            2)
                v-backup-domains
                pause
                ;;
            3)
                print_header
                echo -e "${CYAN}--- Restore domain ---${NC}"
                echo ""
                list_domains_numbered
                if [[ $? -eq 0 ]]; then
                    read -p "Chon domain [1-${#DOMAINS_LIST[@]}]: " d_choice
                    if [[ "$d_choice" =~ ^[0-9]+$ ]] && [[ "$d_choice" -ge 1 ]] && [[ "$d_choice" -le "${#DOMAINS_LIST[@]}" ]]; then
                        local domain="${DOMAINS_LIST[$((d_choice-1))]}"
                        echo ""
                        echo -e "${YELLOW}Backup cua $domain:${NC}"
                        ls -lh /var/backups/ | grep "$domain" || echo "Khong tim thay backup"
                        echo ""
                        read -p "Nhap file backup: " file
                        if [[ -n "$file" ]]; then
                            v-restore-domain "$domain" "/var/backups/$file"
                        fi
                    else
                        echo -e "${RED}Lua chon khong hop le${NC}"
                    fi
                fi
                pause
                ;;
            4)
                echo -e "${YELLOW}Backup directory: /var/backups/${NC}"
                ls -lh /var/backups/
                pause
                ;;
            0)
                break
                ;;
            *)
                echo -e "${RED}Lua chon khong hop le${NC}"
                sleep 1
                ;;
        esac
    done
}

#==============================================================================
# System Management
#==============================================================================
menu_system() {
    while true; do
        print_header
        echo -e "${CYAN}--- Quan ly He thong ---${NC}"
        echo ""
        echo "  1) Kiem tra VPS"
        echo "  2) Khoi dong lai dich vu"
        echo "  3) Trang thai dich vu"
        echo "  4) Reload Nginx"
        echo ""
        echo "  0) Quay lai"
        echo ""
        print_footer

        read -p "Chon so [0-4]: " choice

        case $choice in
            1)
                v-check-vps
                pause
                ;;
            2)
                v-restart restart
                pause
                ;;
            3)
                v-restart status
                pause
                ;;
            4)
                v-restart reload-only
                pause
                ;;
            0)
                break
                ;;
            *)
                echo -e "${RED}Lua chon khong hop le${NC}"
                sleep 1
                ;;
        esac
    done
}

#==============================================================================
# TEMPLATES Management
#==============================================================================
menu_templates() {
    while true; do
        print_header
        echo -e "${CYAN}--- Quan ly Templates ---${NC}"
        echo ""
        echo "  1) Tao domain tu template"
        echo "  2) Xem thong tin template"
        echo ""
        echo "  0) Quay lai"
        echo ""
        print_footer

        read -p "Chon so [0-2]: " choice

        case $choice in
            1)
                create_domain_from_template
                pause
                ;;
            2)
                list_and_show_template_info
                pause
                ;;
            0)
                break
                ;;
            *)
                echo -e "${RED}Lua chon khong hop le${NC}"
                sleep 1
                ;;
        esac
    done
}

# Create domain from template (with numbered selection)
create_domain_from_template() {
    print_header
    echo -e "${CYAN}--- Tao domain tu template ---${NC}"
    echo ""

    read -p "Nhap domain: " domain
    if [[ -z "$domain" ]]; then
        echo -e "${RED}Domain khong duoc de trong${NC}"
        return
    fi

    # List templates with numbers
    echo -e "${YELLOW}Danh sach templates:${NC}"
    echo ""

    local count=0
    local templates=()
    local template_names=()

    # Get templates from v-template-domain --list
    while IFS= read -r line; do
        if [[ "$line" =~ ^[[:space:]]*([0-9]+)\)?[[:space:]]+(.+)[[:space:]]+-[[:space:]]+(.+) ]]; then
            templates+=("${BASH_REMATCH[2]}")
            template_names+=("${BASH_REMATCH[3]}")
            ((count++))
        fi
    done < <(v-template-domain --list 2>/dev/null)

    # Alternative: read from VHOST_DIR
    local SOURCE_DIR="/home/CenterVPS/spanel"
    local VHOST_DIR="$SOURCE_DIR/data/vhost"

    if [[ -d "$VHOST_DIR" ]]; then
        count=0
        templates=()
        template_names=()

        # Find templates in main directory
        for tmpl in "$VHOST_DIR"/*.conf; do
            if [[ -f "$tmpl" ]]; then
                local name=$(basename "$tmpl" .conf)
                local desc=$(grep -m1 "^# Description:" "$tmpl" 2>/dev/null | sed 's/# Description: //' || echo "")
                templates+=("$name")
                template_names+=("$desc")
                ((count++))
            fi
        done

        # Find templates in template subdirectory
        if [[ -d "$VHOST_DIR/template" ]]; then
            for tmpl in "$VHOST_DIR/template"/*.conf; do
                if [[ -f "$tmpl" ]]; then
                    local name=$(basename "$tmpl" .conf)
                    local desc=$(grep -m1 "^# Description:" "$tmpl" 2>/dev/null | sed 's/# Description: //' || echo "")
                    templates+=("$name")
                    template_names+=("$desc")
                    ((count++))
                fi
            done
        fi
    fi

    if [[ ${#templates[@]} -eq 0 ]]; then
        echo -e "${RED}Khong co template nao${NC}"
        return
    fi

    echo -e "  ${CYAN}#${NC}  ${CYAN}Template${NC}                ${CYAN}Mo ta${NC}"
    echo -e "  ${CYAN}--${NC}  ${CYAN}--------${NC}                ${CYAN}-----${NC}"
    for ((i=0; i<count; i++)); do
        echo -e "  ${GREEN}$((i+1))${NC}  ${templates[$i]}  ${template_names[$i]}"
    done
    echo ""

    read -p "Chon template [1-$count]: " choice

    if [[ "$choice" =~ ^[0-9]+$ ]] && [[ "$choice" -ge 1 ]] && [[ "$choice" -le "$count" ]]; then
        local selected="${templates[$((choice-1))]}"
        echo ""
        echo -e "${YELLOW}Chon SSL type:${NC}"
        echo "  1) Khong tao SSL"
        echo "  2) Self-signed SSL"
        echo "  3) Let's Encrypt"
        read -p "Chon so [1-3]: " ssl_choice

        local ssl_arg=""
        case "$ssl_choice" in
            2) ssl_arg="ssl" ;;
            3) ssl_arg="letsencrypt" ;;
            *) ssl_arg="" ;;
        esac

        echo ""
        if [[ -n "$ssl_arg" ]]; then
            v-template-domain "$domain" "$selected" "$ssl_arg"
        else
            v-template-domain "$domain" "$selected"
        fi
    else
        echo -e "${RED}Lua chon khong hop le${NC}"
    fi
}

# List templates and show info
list_and_show_template_info() {
    print_header
    echo -e "${CYAN}--- Xem thong tin Template ---${NC}"
    echo ""

    local count=0
    local templates=()

    local SOURCE_DIR="/home/CenterVPS/spanel"
    local VHOST_DIR="$SOURCE_DIR/data/vhost"

    if [[ -d "$VHOST_DIR" ]]; then
        for tmpl in "$VHOST_DIR"/*.conf; do
            if [[ -f "$tmpl" ]]; then
                templates+=("$(basename "$tmpl" .conf)")
            fi
        done
        if [[ -d "$VHOST_DIR/template" ]]; then
            for tmpl in "$VHOST_DIR/template"/*.conf; do
                if [[ -f "$tmpl" ]]; then
                    templates+=("$(basename "$tmpl" .conf)")
                fi
            done
        fi
    fi

    if [[ ${#templates[@]} -eq 0 ]]; then
        echo -e "${RED}Khong co template nao${NC}"
        return
    fi

    echo -e "${YELLOW}Chon template de xem thong tin:${NC}"
    ((count=${#templates[@]}))
    for ((i=0; i<count; i++)); do
        printf "  ${GREEN}%2d)${NC}  %s\n" $((i+1)) "${templates[$i]}"
    done
    echo ""
    read -p "Chon so [1-$count]: " choice

    if [[ "$choice" =~ ^[0-9]+$ ]] && [[ "$choice" -ge 1 ]] && [[ "$choice" -le "$count" ]]; then
        local selected="${templates[$((choice-1))]}"
        echo ""
        v-template-domain --info "$selected"
    else
        echo -e "${RED}Lua chon khong hop le${NC}"
    fi
}

#==============================================================================
# MAIN MENU
#==============================================================================
main() {
    check_root

    # Create symlink if running from source
    SOURCE_SCRIPT="${BASH_SOURCE[0]}"
    if [[ -L "$SOURCE_SCRIPT" ]]; then
        SOURCE_SCRIPT="$(readlink -f "$SOURCE_SCRIPT")"
    fi
    SOURCE_DIR="$(cd "$(dirname "$SOURCE_SCRIPT")/.." && pwd)"

    # Copy to /var/server/bin if needed
    if [[ -d "/var/server/bin" ]]; then
        if [[ "$SOURCE_DIR" == *"/home/CenterVPS/spanel" ]]; then
            cp -f "$SOURCE_SCRIPT" /var/server/bin/v-manager 2>/dev/null
            ln -sf /var/server/bin/v-manager /usr/local/bin/v-manager 2>/dev/null
        fi
    fi

    while true; do
        print_header
        echo -e "${BOLD}SPanel Manager Menu${NC}"
        echo ""
        echo -e "  ${GREEN}1)${NC} Quan ly Domain"
        echo -e "  ${GREEN}2)${NC} Quan ly SSL"
        echo -e "  ${GREEN}3)${NC} WAF & IP Filter"
        echo -e "  ${GREEN}4)${NC} Backup & Restore"
        echo -e "  ${GREEN}5)${NC} Quan ly He thong"
        echo -e "  ${GREEN}6)${NC} Quan ly Templates"
        echo ""
        echo -e "  ${RED}0)${NC} Thoat"
        echo ""
        print_footer

        read -p "Chon so [0-6]: " choice

        case $choice in
            1)
                menu_domain
                ;;
            2)
                menu_ssl
                ;;
            3)
                menu_waf
                ;;
            4)
                menu_backup
                ;;
            5)
                menu_system
                ;;
            6)
                menu_templates
                ;;
            0)
                echo -e "${GREEN}Tam biet!${NC}"
                exit 0
                ;;
            *)
                echo -e "${RED}Lua chon khong hop le${NC}"
                sleep 1
                ;;
        esac
    done
}

main "$@"
