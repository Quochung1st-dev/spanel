#!/bin/bash
#==============================================================================
# v-delete-domain
# Xoa domain khoi SPanel
#==============================================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

SPANEL_DIR="${SPANEL_DIR:-/var/server}"
BACKUP_DIR="/var/backups"
WWW_DIR="/var/www"
NGINX_CONF="$SPANEL_DIR/nginx/conf"

#------------------------------------------------------------------------------
# Print header
#------------------------------------------------------------------------------

print_header() {
    echo ""
    echo -e "${BLUE}╔════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║       SPanel - Delete Domain            ║${NC}"
    echo -e "${BLUE}╚════════════════════════════════════════╝${NC}"
}

#------------------------------------------------------------------------------
# Check root
#------------------------------------------------------------------------------

check_root() {
    if [[ $EUID -ne 0 ]]; then
        log_error "Can chay voi quyen root"
        exit 1
    fi
}

#------------------------------------------------------------------------------
# Usage
#------------------------------------------------------------------------------

usage() {
    echo ""
    echo "Usage: v-delete-domain <domain> [options]"
    echo ""
    echo "Options:"
    echo "  --force       Khong can xac nhan"
    echo "  --no-backup   Khong backup truoc khi xoa"
    echo "  --list        Danh sach domain"
    echo ""
    echo "Backup dir: /var/backups"
    echo "Commands:"
    echo "  v-delete-domain <domain>      Xoa domain"
    echo "  v-delete-domain --list        Danh sach domain"
    echo ""
    echo "Examples:"
    echo "  v-delete-domain example.com"
    echo "  v-delete-domain example.com --force --no-backup"
    exit 1
}

#------------------------------------------------------------------------------
# List domains
#------------------------------------------------------------------------------

list_domains() {
    echo ""
    echo -e "${BLUE}── Domain List ──${NC}"
    echo ""

    local count=0

    if [[ -d "$NGINX_CONF/sites-available" ]]; then
        for conf in "$NGINX_CONF/sites-available"/*.conf; do
            [[ -f "$conf" ]] || continue

            local domain=$(basename "$conf" .conf)
            [[ "$domain" == "default" ]] && continue
            [[ "$domain" == "panel" ]] && continue

            ((count++))

            local status="${YELLOW}disabled${NC}"
            [[ -L "$NGINX_CONF/sites-enabled/$domain.conf" ]] && status="${GREEN}enabled${NC}"

            printf "  ${CYAN}%-25s${NC} | $status\n" "$domain"
        done
    fi

    echo ""
    echo "Total: $count domains"
    echo ""
}

#------------------------------------------------------------------------------
# Backup domain
#------------------------------------------------------------------------------

backup_domain() {
    local domain=$1

    local backup_dir="$BACKUP_DIR"
    mkdir -p "$backup_dir"

    local timestamp=$(date +%Y%m%d_%H%M%S)
    local backup_file="$backup_dir/${domain}_${timestamp}.tar.gz"

    if [[ -d "$WWW_DIR/$domain" ]]; then
        tar -czf "$backup_file" -C "$WWW_DIR" "$domain" 2>/dev/null
        log_info "Backup: $backup_file"
    fi

    if [[ -d "$WWW_DIR/$domain/ssl" ]]; then
        tar -czf "$backup_dir/ssl_${domain}_${timestamp}.tar.gz" -C "$WWW_DIR" "$domain/ssl" 2>/dev/null
    fi
}

#------------------------------------------------------------------------------
# Disable domain
#------------------------------------------------------------------------------

disable_domain() {
    local domain=$1

    local enabled_link="$NGINX_CONF/sites-enabled/$domain.conf"

    if [[ -L "$enabled_link" ]]; then
        rm -f "$enabled_link"
        log_info "Da disable $domain"
    fi

    # Reload nginx bang v-restart
    bash "$BIN_DIR/v-restart" reload-only 2>/dev/null || true
}

#------------------------------------------------------------------------------
# Delete domain
#------------------------------------------------------------------------------

delete_domain() {
    local domain=$1
    local force=$2
    local no_backup=$3

    # Check domain exists
    if [[ ! -d "$WWW_DIR/$domain" ]] && [[ ! -f "$NGINX_CONF/sites-available/$domain.conf" ]]; then
        log_error "Domain '$domain' khong ton tai"
        return 1
    fi

    print_header
    echo ""
    echo "Domain: $domain"
    echo ""

    # Delete without confirmation (always force)
    # Backup
    if [[ "$no_backup" != "yes" ]]; then
        backup_domain "$domain"
    fi

    # Disable
    disable_domain "$domain"

    # Delete nginx config
    rm -f "$NGINX_CONF/sites-available/$domain.conf"
    log_info "Da xoa nginx config"

    # Delete www directory
    if [[ -d "$WWW_DIR/$domain" ]]; then
        rm -rf "$WWW_DIR/$domain"
        log_info "Da xoa thu muc www"
    fi

    # Delete SSL (now in www/domain/ssl)
    if [[ -d "$WWW_DIR/$domain/ssl" ]]; then
        rm -rf "$WWW_DIR/$domain/ssl"
        log_info "Da xoa SSL"
    fi

    echo ""
    log_info "Da xoa domain $domain thanh cong!"
    echo ""
}

#------------------------------------------------------------------------------
# MAIN
#------------------------------------------------------------------------------

main() {
    check_root

    if [[ $# -eq 0 ]]; then
        usage
    fi

    local domain=""
    local force="no"
    local no_backup="no"

    # Parse arguments
    for arg in "$@"; do
        case "$arg" in
            --force)
                force="yes"
                ;;
            --no-backup)
                no_backup="yes"
                ;;
            --list)
                list_domains
                exit 0
                ;;
            -h|--help)
                usage
                ;;
            *)
                domain="$arg"
                ;;
        esac
    done

    if [[ -z "$domain" ]]; then
        usage
    fi

    delete_domain "$domain" "$force" "$no_backup"
}

main "$@"