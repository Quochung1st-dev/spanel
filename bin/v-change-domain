#!/bin/bash
#==============================================================================
# v-change-domain
# Thay đổi cấu hình domain trong SPanel
#==============================================================================

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

SPANEL_DIR="${SPANEL_DIR:-/var/server}"
NGINX_CONF_DIR="$SPANEL_DIR/nginx"
SPANEL_USER="${SPANEL_USER:-spanel}"
SPANEL_GROUP="${SPANEL_GROUP:-spanel}"

#------------------------------------------------------------------------------
# Change domain document root
#------------------------------------------------------------------------------

change_document_root() {
    local domain=$1
    local new_root=$2

    log_info "Đổi document root của $domain thành $new_root..."

    local conf_file="$NGINX_CONF_DIR/sites-available/$domain.conf"

    if [[ ! -f $conf_file ]]; then
        log_error "Không tìm thấy config của $domain"
        return 1
    fi

    if [[ ! -d $new_root ]]; then
        log_error "Thư mục $new_root không tồn tại"
        return 1
    fi

    # Thay thế document root
    sed -i "s|root .*;|root $new_root;|g" $conf_file

    # Reload nginx
    $SPANEL_DIR/nginx/sbin/nginx -t 2>/dev/null && \
        $SPANEL_DIR/nginx/sbin/nginx -s reload

    log_info "Đã đổi document root"
}

#------------------------------------------------------------------------------
# Change domain port
#------------------------------------------------------------------------------

change_port() {
    local domain=$1
    local new_port=$2

    log_info "Đổi port của $domain thành $new_port..."

    local conf_file="$NGINX_CONF_DIR/sites-available/$domain.conf"

    if [[ ! -f $conf_file ]]; then
        log_error "Không tìm thấy config của $domain"
        return 1
    fi

    # Thay thế port
    sed -i "s|listen .*;|listen $new_port;|g" $conf_file

    # Reload nginx
    $SPANEL_DIR/nginx/sbin/nginx -t 2>/dev/null && \
        $SPANEL_DIR/nginx/sbin/nginx -s reload

    log_info "Đã đổi port"
}

#------------------------------------------------------------------------------
# Enable/Disable SSL
#------------------------------------------------------------------------------

toggle_ssl() {
    local domain=$1
    local enable=${2:-true}

    log_info "SSL cho $domain: $([[ $enable == true ]] && echo 'bật' || echo 'tắt')"

    local conf_file="$NGINX_CONF_DIR/sites-available/$domain.conf"
    local cert_dir="$SPANEL_DIR/ssl/$domain"

    if [[ ! -f $conf_file ]]; then
        log_error "Không tìm thấy config của $domain"
        return 1
    fi

    if [[ $enable == true ]]; then
        # Kiểm tra certificate
        if [[ ! -f $cert_dir/fullchain.pem ]]; then
            log_error "Certificate SSL không tồn tại cho $domain"
            return 1
        fi

        # Thêm SSL config vào server block
        if ! grep -q "listen 443 ssl" $conf_file; then
            # Tạo file config mới với SSL
            local tmp_conf="/tmp/nginx_conf_$$"
            cat > $tmp_conf <<EOF
server {
    listen 80;
    server_name $domain;
    return 301 https://\$server_name\$request_uri;
}

server {
    listen 443 ssl http2;
    server_name $domain;

    root $SCRIPT_DIR/var/www/$domain/public_html;
    index index.php index.html index.htm;

    access_log $SCRIPT_DIR/var/www/$domain/logs/nginx/access.log;
    error_log $SCRIPT_DIR/var/www/$domain/logs/nginx/error.log;

    ssl_certificate $cert_dir/fullchain.pem;
    ssl_certificate_key $cert_dir/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers on;

    # Lua modules
    set \$lua_root $SPANEL_DIR/lua;
    set \$waf_mode active;
    set \$waf_rule_dir $SPANEL_DIR/waf/rules;
    set \$cache_enabled true;

    include $SPANEL_DIR/nginx/conf.d/cache.conf;
    include $SPANEL_DIR/nginx/conf.d/lua.conf;
    include $SPANEL_DIR/nginx/conf.d/waf.conf;
}
EOF
            cp $tmp_conf $conf_file
            rm $tmp_conf
        fi
    else
        # Xóa SSL config
        log_warn "Chưa hỗ trợ tắt SSL - cần tạo lại vhost không có SSL"
    fi

    # Reload nginx
    $SPANEL_DIR/nginx/sbin/nginx -t 2>/dev/null && \
        $SPANEL_DIR/nginx/sbin/nginx -s reload

    log_info "Đã cập nhật SSL"
}

#------------------------------------------------------------------------------
# Change PHP version
#------------------------------------------------------------------------------

change_php() {
    local domain=$1
    local php_version=${2:-php81}

    log_info "Đổi PHP version thành $php_version cho $domain..."

    local conf_file="$NGINX_CONF_DIR/sites-available/$domain.conf"

    if [[ ! -f $conf_file ]]; then
        log_error "Không tìm thấy config của $domain"
        return 1
    fi

    # Thêm hoặc cập nhật PHP config
    if grep -q "fastcgi_pass" $conf_file; then
        sed -i "s|fastcgi_pass .*;|fastcgi_pass unix:/run/php/${php_version}-fpm.sock;|g" $conf_file
    fi

    # Reload nginx
    $SPANEL_DIR/nginx/sbin/nginx -t 2>/dev/null && \
        $SPANEL_DIR/nginx/sbin/nginx -s reload

    log_info "Đã đổi PHP version"
}

#------------------------------------------------------------------------------
# Change cache settings
#------------------------------------------------------------------------------

change_cache() {
    local domain=$1
    local enabled=${2:-true}

    log_info "Cache cho $domain: $([[ $enabled == true ]] && echo 'bật' || echo 'tắt')"

    local conf_file="$NGINX_CONF_DIR/sites-available/$domain.conf"

    if [[ ! -f $conf_file ]]; then
        log_error "Không tìm thấy config của $domain"
        return 1
    fi

    sed -i "s|set \$cache_enabled .*;|set \$cache_enabled $([[ $enabled == true ]] && echo 'true' || echo 'false');|g" $conf_file

    # Reload nginx
    $SPANEL_DIR/nginx/sbin/nginx -t 2>/dev/null && \
        $SPANEL_DIR/nginx/sbin/nginx -s reload

    log_info "Đã cập nhật cache"
}

#------------------------------------------------------------------------------
# Change WAF mode
#------------------------------------------------------------------------------

change_waf() {
    local domain=$1
    local mode=${2:-active}

    log_info "WAF mode thành $mode cho $domain..."

    local conf_file="$NGINX_CONF_DIR/sites-available/$domain.conf"

    if [[ ! -f $conf_file ]]; then
        log_error "Không tìm thấy config của $domain"
        return 1
    fi

    sed -i "s|set \$waf_mode .*;|set \$waf_mode $mode;|g" $conf_file

    # Reload nginx
    $SPANEL_DIR/nginx/sbin/nginx -t 2>/dev/null && \
        $SPANEL_DIR/nginx/sbin/nginx -s reload

    log_info "Đã cập nhật WAF mode"
}

#------------------------------------------------------------------------------
# Show help
#------------------------------------------------------------------------------

show_help() {
    echo -e "${BLUE}v-change-domain - Thay đổi cấu hình domain${NC}"
    echo ""
    echo "Usage: $0 <command> [arguments]"
    echo ""
    echo "Commands:"
    echo "  document-root <domain> <path>     Đổi document root"
    echo "  port <domain> <port>              Đổi port"
    echo "  ssl <domain> <on|off>             Bật/tắt SSL"
    echo "  php <domain> <version>            Đổi PHP version (php74, php81, php82)"
    echo "  cache <domain> <on|off>           Bật/tắt cache"
    echo "  waf <domain> <mode>              Đổi WAF mode (active, passive, off)"
    echo ""
    echo "Examples:"
    echo "  $0 document-root example.com /var/www/example.com/public"
    echo "  $0 port example.com 8080"
    echo "  $0 ssl example.com on"
    echo "  $0 cache example.com off"
}

#------------------------------------------------------------------------------
# MAIN
#------------------------------------------------------------------------------

main() {
    local command=${1:-help}

    case $command in
        document-root)
            change_document_root $2 $3
            ;;
        port)
            change_port $2 $3
            ;;
        ssl)
            local enable=$([[ $3 == "on" ]] && echo "true" || echo "false")
            toggle_ssl $2 $enable
            ;;
        php)
            change_php $2 $3
            ;;
        cache)
            local enabled=$([[ $3 == "on" ]] && echo "true" || echo "false")
            change_cache $2 $enabled
            ;;
        waf)
            change_waf $2 $3
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            log_error "Lệnh không hợp lệ: $command"
            show_help
            exit 1
            ;;
    esac
}

main "$@"