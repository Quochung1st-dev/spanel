#!/bin/bash
#==============================================================================
# v-backup-domain
# Backup domain data
#==============================================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

SPANEL_DIR="${SPANEL_DIR:-/var/server}"
WWW_DIR="/var/www"
BACKUP_DIR="/var/backups"
BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

#------------------------------------------------------------------------------
# Check root
#------------------------------------------------------------------------------

check_root() {
    if [[ $EUID -ne 0 ]]; then
        log_error "Can chay voi quyen root"
        exit 1
    fi
}

#------------------------------------------------------------------------------
# Print header
#------------------------------------------------------------------------------

print_header() {
    echo ""
    echo -e "${BLUE}╔════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║       SPanel - Backup Domain            ║${NC}"
    echo -e "${BLUE}╚════════════════════════════════════════╝${NC}"
}

#------------------------------------------------------------------------------
# Usage
#------------------------------------------------------------------------------

usage() {
    echo ""
    echo "Usage: v-backup-domain <domain> [options]"
    echo ""
    echo "Options:"
    echo "  --all    Backup tat ca domain"
    echo "  --list   Danh sach backup hien co"
    echo ""
    echo "Examples:"
    echo "  v-backup-domain example.com"
    echo "  v-backup-domain --all"
    echo "  v-backup-domain --list"
    exit 1
}

#------------------------------------------------------------------------------
# List backups
#------------------------------------------------------------------------------

list_backups() {
    echo ""
    echo -e "${BLUE}── Backup List ──${NC}"
    echo ""

    if [[ ! -d "$BACKUP_DIR" ]]; then
        echo "Khong co backup nao"
        return
    fi

    local count=0
    for f in "$BACKUP_DIR"/*.tar.gz; do
        [[ -f "$f" ]] || continue
        ((count++))
        local size=$(du -h "$f" | awk '{print $1}')
        local date=$(stat -c %y "$f" 2>/dev/null | cut -d' ' -f1 || date -r "$f" +%Y-%m-%d)
        echo "  $(basename "$f") | $size | $date"
    done

    echo ""
    echo "Total: $count backups"
    echo ""
}

#------------------------------------------------------------------------------
# Backup single domain
#------------------------------------------------------------------------------

backup_domain() {
    local domain=$1

    if [[ -z "$domain" ]]; then
        log_error "Vui long nhap domain"
        return 1
    fi

    if [[ ! -d "$WWW_DIR/$domain" ]]; then
        log_error "Domain '$domain' khong ton tai"
        return 1
    fi

    print_header
    echo ""
    echo "Domain: $domain"
    echo ""

    # Create backup dir
    mkdir -p "$BACKUP_DIR"

    local timestamp=$(date +%Y%m%d_%H%M%S)
    local backup_file="$BACKUP_DIR/${domain}_${timestamp}.tar.gz"

    # Backup www
    log_info "Backup www..."
    tar -czf "$backup_file" -C "$WWW_DIR" "$domain" 2>/dev/null

    if [[ -f "$backup_file" ]]; then
        local size=$(du -h "$backup_file" | awk '{print $1}')
        log_info "Backup thanh cong!"
        echo ""
        echo "  File: $backup_file"
        echo "  Size: $size"
    else
        log_error "Backup that bai"
        return 1
    fi

    echo ""
}

#------------------------------------------------------------------------------
# Backup all domains
#------------------------------------------------------------------------------

backup_all() {
    print_header
    echo ""
    echo "Backup tat ca domain..."
    echo ""

    local count=0

    if [[ -d "$WWW_DIR" ]]; then
        for domain_dir in "$WWW_DIR"/*; do
            [[ -d "$domain_dir" ]] || continue
            local domain=$(basename "$domain_dir")
            backup_domain "$domain"
            ((count++))
        done
    fi

    echo ""
    log_info "Da backup $count domains"
    echo ""
}

#------------------------------------------------------------------------------
# MAIN
#------------------------------------------------------------------------------

main() {
    check_root

    if [[ $# -eq 0 ]]; then
        usage
    fi

    local domain=""
    local mode="single"

    for arg in "$@"; do
        case "$arg" in
            --all)
                mode="all"
                ;;
            --list)
                list_backups
                exit 0
                ;;
            -h|--help)
                usage
                ;;
            *)
                domain="$arg"
                ;;
        esac
    done

    if [[ "$mode" == "all" ]]; then
        backup_all
    else
        backup_domain "$domain"
    fi
}

main "$@"
